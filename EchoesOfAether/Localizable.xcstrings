    "quest.sageHerb.active": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The moonherb... a pale glow between the roots, west of the trail."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'herbe lunaire... une lueur pâle entre les racines, à l'ouest du sentier."
          }
        }
      }
    },
    "quest.sageHerb.decline": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Another time."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une autre fois."
          }
        }
      }
    },
    "quest.sageHerb.declineResponse": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Of course. The teas will wait."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bien sûr. Les tisanes attendront."
          }
        }
      }
    },
    "quest.sageHerb.done1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You found it! Its scent alone restores your strength."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu l'as trouvée ! Son parfum seul redonne des forces."
          }
        }
      }
    },
    "quest.sageHerb.done2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Here. And the next tea is on me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiens. Et la prochaine tisane est pour moi."
          }
        }
      }
    },
    "quest.sageHerb.found": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
