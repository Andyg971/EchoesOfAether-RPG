    "prologue.line1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A thousand years ago, the Source sang at the heart of the world."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il y a mille ans, la Source chantait au cœur du monde."
          }
        }
      }
    },
    "prologue.line2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Its Aether flowed through every stone, every tree, every living thing."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Son Aether coulait dans chaque pierre, chaque arbre, chaque être vivant."
          }
        }
      }
    },
    "prologue.line3": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then someone tried to claim it. And the Source fell silent."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Puis quelqu'un a voulu la posséder. Et la Source s'est tue."
          }
        }
      }
    },
    "prologue.line4": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Since then, black Aether gnaws at the land and marks those it chooses."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Depuis, l'Aether noir ronge la terre et marque ceux qu'il choisit."
          }
        }
      }
    },
    "prologue.line5": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A man awoke at the edge of the forest. No memory. Except for a name."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un homme s'est éveillé à la lisière de la forêt. Sans mémoire. Sauf d'un nom."
          }
        }
      }
    },
    "prologue.skip": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap to skip"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toucher pour passer"
          }
        }
      }
    },
    "quest.bramOre.accept": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'll bring some back."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'en rapporterai."
          }
        }
      }
    },
    "quest.bramOre.acceptResponse": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Look for the dark vein on the west trail, below the clearing. And don't linger out there."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cherche la veine sombre sur le sentier ouest, sous la clairière. Et ne traîne pas là-bas."
          }
        }
      }
    },
    "quest.bramOre.active": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "So, that iron? The dark vein, west trail, below the clearing."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors, ce fer ? La veine sombre, sentier ouest, sous la clairière."
          }
        }
      }
    },
    "quest.bramOre.decline": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not now."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas maintenant."
          }
        }
      }
    },
    "quest.bramOre.declineResponse": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Suit yourself. The forge will wait."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comme tu veux. La forge attendra."
          }
        }
      }
    },
    "quest.bramOre.done1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By all the fires... look at that grain. Here, for your trouble."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Par tous les feux... regarde-moi ce grain. Tiens, pour ta peine."
          }
        }
      }
    },
    "quest.bramOre.done2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Come back anytime. The forge owes you a favor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Repasse quand tu veux. La forge te doit une faveur."
          }
        }
      }
    },
    "quest.bramOre.found": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A vein of blackened iron. The metal is cold… colder than it should be."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une veine de fer noirci. Le métal est froid… plus froid qu'il ne devrait."
          }
        }
      }
    },
    "quest.bramOre.hud": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find the corrupted iron (forest)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trouver le fer corrompu (forêt)"
          }
        }
      }
    },
    "quest.bramOre.offer1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The forge is short on good iron. The forest veins are corrupted… but corrupted iron, properly purged, makes steel like no other."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La forge manque de bon fer. Les veines de la forêt sont corrompues… mais un fer corrompu, bien purgé, donne un acier sans pareil."
          }
        }
      }
    },
    "quest.bramOre.offer2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring corrupted iron back to Bram?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rapporter du fer corrompu à Bram ?"
          }
        }
      }
    },
    "quest.childToy.name": {
