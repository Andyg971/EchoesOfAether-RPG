      }
    },

    "shop.bram.ironBlade.name" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Lame de Fer" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Iron Blade" } }
      }
    },
    "shop.bram.ironBlade.desc" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "+22 ATK / +35 Entaille" } },
