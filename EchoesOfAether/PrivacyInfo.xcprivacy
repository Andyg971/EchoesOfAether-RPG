<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Aucun suivi publicitaire, aucun SDK tiers, aucun réseau. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!-- Aucune donnée ne quitte l'appareil : pas d'analytics, pas de compte.
	     Les sauvegardes restent locales, avec un miroir dans l'iCloud du
	     joueur (NSUbiquitousKeyValueStore) auquel le développeur n'a pas accès. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- UserDefaults : réglages du jeu (audio, tutoriel vu, options
			     d'accessibilité). Données de l'app, lisibles par l'app seule. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
