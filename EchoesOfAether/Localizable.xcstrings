    "lore.eran.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Aether does not choose. It reveals what was already there."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'Aether ne choisit pas. Il révèle ce qui était déjà là."
          }
        }
      }
    },
    "lore.eran.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Eran's Inscription"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Inscription d'Eran"
          }
        }
      }
    },
    "lore.kaelMemories.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Three fragments wrested from the Void: a mother's voice, a friend's laughter, a hand reaching for the red light. The Void erases; remembering is an act of resistance."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trois fragments arrachés au Vide : une voix de mère, un rire d'amie, une main tendue vers la lumière rouge. Le Vide efface ; se souvenir est un acte de résistance."
          }
        }
      }
    },
    "lore.kaelMemories.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael's Memories"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les souvenirs de Kael"
          }
        }
      }
    },
