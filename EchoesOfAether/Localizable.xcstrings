          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le combat est au tour par tour : à ton tour, choisis Attaque, un sort élémentaire ou l'Entaille Noire. Vise les faiblesses pour briser la garde (BREAK) et dépense tes BP pour booster."
          }
        }
      }
    },
