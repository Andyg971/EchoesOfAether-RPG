          }
        }
      }
    },
    "dialogue.act2.archivist.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I don't know you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne te connais pas."
          }
        }
      }
    },
    "dialogue.act2.archivist.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Archivist"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'Archiviste"
          }
        }
      }
    },
    "dialogue.act2.archivist.post.vision": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vision. The Source pulses. My blood... not my will."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vision. La Source pulse. Mon sang... pas ma volonté."
          }
        }
      }
    },
    "dialogue.act2.archivist.post1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These... voices. All at once."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces... voix. Toutes en même temps."
          }
        }
      }
    },
    "dialogue.act2.archivist.post2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. There's something on the wall, near the main inscription."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. Il y a quelque chose sur le mur, près de l'inscription principale."
          }
        }
      }
    },
    "dialogue.act2.archivist.post3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Come. The inscription... it responds to something in you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Viens. L'inscription... elle répond à quelque chose en toi."
          }
        }
      }
    },
    "dialogue.act2.archivist.pre1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Collector. You've finally come back to claim your name."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collecteur. Tu es enfin revenu chercher ton nom."
          }
        }
      }
    },
    "dialogue.act2.archivist.pre2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every soul you've taken... I've catalogued them all."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque âme que tu as prise... je les ai cataloguées."
          }
        }
      }
    },
    "dialogue.act2.archivist.pre3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "But they know you. They told me everything."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mais elles te connaissent. Elles m'ont tout raconté."
          }
        }
      }
    },
    "dialogue.act2.bram.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. They say you brought down the shrine's Guardian. …Is it true, what they say about your eyes?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. On raconte que t'as terrassé le Gardien du sanctuaire. …C'est vrai, ce qu'on dit sur tes yeux ?"
          }
        }
      }
    },
    "dialogue.act2.bram.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bah. As long as you're buying, the forge asks no questions."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bah. Tant que t'achètes, la forge pose pas de questions."
          }
        }
      }
    },
    "dialogue.act2.child.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "…"
          }
        }
      }
    },
    "dialogue.act2.child.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mom says I'm not allowed to talk to you anymore. You're not the same, Kael. Your eyes… they're scary."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maman dit que je dois plus te parler. T'es plus pareil, Kael. Tes yeux… ils font peur."
          }
        }
      }
    },
    "dialogue.act2.child.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "…Maybe she's right, kid."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "…Elle a peut-être raison, petit."
          }
        }
      }
    },
    "dialogue.act2.death.eran.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Too late, Lyra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trop tard, Lyra."
          }
        }
      }
    },
    "dialogue.act2.death.eran.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Eran was right... The Threshold can still..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eran avait raison... Le Seuil peut encore..."
          }
        }
      }
    },
    "dialogue.act2.death.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can't hear you anymore, Lyra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne t'entends plus, Lyra."
          }
        }
      }
    },
    "dialogue.act2.death.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... you're hurting me. Let go..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... tu me fais mal. Lâche-moi..."
          }
        }
      }
    },
    "dialogue.act2.death.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "... Kael..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "... Kael..."
          }
        }
      }
    },
    "dialogue.act2.discovery.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That's not me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce n'est pas moi."
          }
        }
      }
    },
    "dialogue.act2.discovery.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't understand what you're reading."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu ne comprends pas ce que tu lis."
          }
        }
      }
    },
    "dialogue.act2.discovery.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "..."
          }
        }
      }
    },
    "dialogue.act2.discovery.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyra... please."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyra... je t'en supplie."
          }
        }
      }
    },
    "dialogue.act2.discovery.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wait. This inscription... it's different from the others."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attends. Cette inscription... elle est différente des autres."
          }
        }
      }
    },
    "dialogue.act2.discovery.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "'Kael, Blade of the Void, Soul Collector, Executor of the Corrupted Source.'"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "'Kael, Lame du Vide, Collecteur d'Âmes, Exécuteur de la Source Corrompue.'"
          }
        }
      }
    },
    "dialogue.act2.discovery.lyra3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... did you know? Those disappearances in Solis... was that you?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... tu savais ? Ces disparitions à Solis... c'était toi ?"
          }
        }
      }
    },
    "dialogue.act2.discovery.lyra4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can't stay silent. Solis needs to know the truth. I have to go."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne peux pas me taire. Solis doit savoir la vérité. Je dois y aller."
          }
        }
      }
    },
    "dialogue.act2.discovery.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reply to Lyra"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Répondre à Lyra"
          }
        }
      }
    },
    "dialogue.act2.discovery.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The inscription bears your Aether mark. Kael, please, tell me I'm wrong."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'inscription porte ta marque d'Aether. Kael, je t'en supplie, dis-moi que je me trompe."
          }
        }
      }
    },
    "dialogue.act2.discovery.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can read just fine. And it matches everything. The nights you disappeared. The people who vanished."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je lis très bien. Ça correspond à tout. Les nuits où tu disparaissais. Les gens qui se volatilisaient."
          }
        }
      }
    },
    "dialogue.act2.dorin.block.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move aside."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pousse-toi."
          }
        }
      }
    },
    "dialogue.act2.dorin.block.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I understand your distrust."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je comprends ta méfiance."
          }
        }
      }
    },
    "dialogue.act2.dorin.block.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What do you say to Dorin?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Que répondre à Dorin ?"
          }
        }
      }
    },
    "dialogue.act2.dorin.block.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No. Not until I know you won't hurt her."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non. Pas avant que je sache que tu ne lui feras pas de mal."
          }
        }
      }
    },
    "dialogue.act2.dorin.block.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Distrust... Yes. Because I've seen what you're becoming."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Méfiance... Oui. Parce que j'ai vu ce que tu deviens."
          }
        }
      }
    },
    "dialogue.act2.dorin.block1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No. I won't let you take her there."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non. Je ne te laisserai pas l'emmener là-bas."
          }
        }
      }
    },
    "dialogue.act2.dorin.block2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Those ruins have consumed souls far purer than yours, Kael."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces ruines ont brûlé des âmes bien plus pures que la tienne, Kael."
          }
        }
      }
    },
    "dialogue.act2.dorin.block3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Protect her. That's all I ask of you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Protège-la. C'est tout ce que je te demande."
          }
        }
      }
    },
    "dialogue.act2.dorin.doubt1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You came back from the shrine changed. I see it in your eyes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu reviens du sanctuaire changé. Je le vois dans tes yeux."
          }
        }
      }
    },
    "dialogue.act2.dorin.doubt2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I hope so. For everyone's sake, I really hope I'm wrong."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'espère. Pour tous, j'espère vraiment me tromper."
          }
        }
      }
    },
    "dialogue.act2.dorin.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're wrong, Dorin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu te trompes, Dorin."
          }
        }
      }
    },
    "dialogue.act2.eran.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "E... Eran. She was here."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "E... Eran. Elle a été ici."
          }
        }
      }
    },
    "dialogue.act2.eran.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Or she knew what was going to happen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ou elle savait ce qui allait arriver."
          }
        }
      }
    },
    "dialogue.act2.eran.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wait... these runes don't look like the others."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attends... ces runes ne ressemblent pas aux autres."
          }
        }
      }
    },
    "dialogue.act2.eran.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "«It's not too late. Seek the Threshold. E.»"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "«Il n'est pas trop tard. Cherche le Seuil. E.»"
          }
        }
      }
    },
    "dialogue.act2.eran.lyra3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Eran Solace? The missing researcher? But... that's impossible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eran Solace ? La chercheuse disparue ? Mais... c'est impossible."
          }
        }
      }
    },
    "dialogue.act2.fallen.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "She was right. About everything."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Elle avait raison. Sur tout."
          }
        }
      }
    },
    "dialogue.act2.fallen.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "But the dead don't speak."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mais les morts ne parlent pas."
          }
        }
      }
    },
    "dialogue.act2.fallen.kael3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oui."
          }
        }
      }
    },
    "dialogue.act2.fallen.voice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are free. Come."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu es libre. Viens."
          }
        }
      }
    },
    "dialogue.act2.gift.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'll keep it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je le garde."
          }
        }
      }
    },
    "dialogue.act2.gift.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I don't need it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je n'en ai pas besoin."
          }
        }
      }
    },
    "dialogue.act2.gift.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "... I promise."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "... Promis."
          }
        }
      }
    },
    "dialogue.act2.gift.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wait."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attends."
          }
        }
      }
    },
    "dialogue.act2.gift.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take this. A resonance crystal. It absorbs black Aether... a little."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prends ça. Un cristal de résonance. Il absorbe l'Aether noir... un peu."
          }
        }
      }
    },
    "dialogue.act2.gift.lyra3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep it. Promise?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Garde-le. Promis ?"
          }
        }
      }
    },
    "dialogue.act2.gift.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What to do with the crystal?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Que faire du cristal ?"
          }
        }
      }
    },
    "dialogue.act2.gift.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Good. Don't lose it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bien. Ne le perds pas."
          }
        }
      }
    },
    "dialogue.act2.gift.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yes you do. More than you think."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si. Tu en as besoin. Plus que tu ne le crois."
          }
        }
      }
    },
    "dialogue.act2.lyra.analysis1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This data... the Aether shards you helped me collect. They carried imprints."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces données... les éclats d'Aether que tu m'as aidé à collecter. Ils portaient des empreintes."
          }
        }
      }
    },
    "dialogue.act2.lyra.analysis2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Imprints of someone who passed through before you. Before us."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des empreintes de quelqu'un qui est passé avant toi. Avant nous."
          }
        }
      }
    },
    "dialogue.act2.lyra.analysis3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm not sure yet. But there's something in the Sage's old texts."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne suis pas encore sûre. Mais il y a quelque chose dans les vieux textes du Sage."
          }
        }
      }
    },
    "dialogue.act2.lyra.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What do you mean?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Que veux-tu dire ?"
          }
        }
      }
    },
    "dialogue.act2.mara.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Come closer… Hmm. You smell of black Aether, Kael. It clings to the skin. None of my herbs will change that."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Approche… Hmm. Tu sens l'Aether noir, Kael. Ça colle à la peau. Aucune de mes herbes n'y changera rien."
          }
        }
      }
    },
    "dialogue.act2.mara.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take what you need. And… look after Lyra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prends ce qu'il te faut. Et… veille sur Lyra."
          }
        }
      }
    },
    "dialogue.act2.nightmare.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shut up. Shut up..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tais-toi. Tais-toi..."
          }
        }
      }
    },
    "dialogue.act2.nightmare.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I belong to no one."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je n'appartiens à personne."
          }
        }
      }
    },
    "dialogue.act2.nightmare.kael3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "...It was nothing. Go back to sleep."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "...C'était rien. Rendors-toi."
          }
        }
      }
    },
    "dialogue.act2.nightmare.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. Kael, wake up. You were screaming."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. Kael, réveille-toi. Tu criais."
          }
        }
      }
    },
    "dialogue.act2.nightmare.voice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Solis. Five nights. Seven souls."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Solis. Cinq nuits. Sept âmes."
          }
        }
      }
    },
    "dialogue.act2.nightmare.voice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You remember the names. You remember every gesture."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu te souviens des noms. Tu te souviens de chaque geste."
          }
        }
      }
    },
    "dialogue.act2.nightmare.voice3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Source claims you. It is your blood. It is your name."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La Source te réclame. C'est ton sang. C'est ton nom."
          }
        }
      }
    },
    "dialogue.act2.return.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That Aether Core... that dark energy. It still resonates inside me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce Noyau d'Aether... cette énergie noire. Elle résonne encore en moi."
          }
        }
      }
    },
    "dialogue.act2.return.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take all the time you need."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prends le temps qu'il te faut."
          }
        }
      }
    },
    "dialogue.act2.return.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We're alive. I still can't believe it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous sommes vivants. Je n'arrive toujours pas à y croire."
          }
        }
      }
    },
    "dialogue.act2.return.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I recorded data at the shrine. I need time to analyze it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'ai enregistré des données au sanctuaire. J'ai besoin de temps pour analyser ça."
          }
        }
      }
    },
    "dialogue.act2.ruins.combat1.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "They're protecting something. Keep moving."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ils protègent quelque chose. Continue à avancer."
          }
        }
      }
    },
    "dialogue.act2.ruins.combat1.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Corrupted Guardians. The black Aether still controls them."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des Gardiens corrompus. L'Aether noir les contrôle encore."
          }
        }
      }
    },
    "dialogue.act2.ruins.combat2.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These souls were travelers. The Aether trapped them."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces âmes étaient des voyageurs. L'Aether les a piégés."
          }
        }
      }
    },
    "dialogue.act2.ruins.combat2.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "There's something deeper here. An inscription at the back..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il y a quelque chose de plus profond ici. Une inscription au fond..."
          }
        }
      }
    },
    "dialogue.act2.ruins.enter.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I feel... at home here. Strange."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je me sens... chez moi ici. C'est étrange."
          }
        }
      }
    },
    "dialogue.act2.ruins.enter.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Ruins of the Source... centuries old. Look at these inscriptions."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les Ruines de la Source... elles ont des siècles. Regarde ces inscriptions."
          }
        }
      }
    },
    "dialogue.act2.ruins.enter.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael, it worries me when you say that."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael, ça m'inquiète quand tu dis ça."
          }
        }
      }
    },
    "dialogue.act2.sage.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Why are you telling me this now?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pourquoi me parles-tu de ça maintenant ?"
          }
        }
      }
    },
    "dialogue.act2.sage.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm listening."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je t'écoute."
          }
        }
      }
    },
    "dialogue.act2.sage.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reply to the Sage"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Répondre au Sage"
          }
        }
      }
    },
    "dialogue.act2.sage.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Because you returned from the shrine. And the ruins... reacted to your arrival."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parce que tu es revenu du sanctuaire. Et les ruines ont... réagi à ton arrivée."
          }
        }
      }
    },
    "dialogue.act2.sage.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The inscriptions there might explain what you've been feeling since you woke up."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les inscriptions là-bas pourraient expliquer ce que tu ressens depuis ton réveil."
          }
        }
      }
    },
    "dialogue.act2.sage.reveal1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. I need to tell you something important."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. Je dois te dire quelque chose d'important."
          }
        }
      }
    },
    "dialogue.act2.sage.reveal2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To the northeast lie the Ruins of the Source. The original Source of Aether."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Au nord-est du village se trouvent les Ruines de la Source. La Source originelle de l'Aether."
          }
        }
      }
    },
    "dialogue.act2.sage.reveal3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Be careful. And take Lyra. She can read the symbols."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sois prudent. Et emmène Lyra. Elle saura lire les symboles."
          }
        }
      }
    },
    "dialogue.act2.villager.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The hero of Solis… We owe you so much. Then why does everyone shut their shutters when you walk by?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le héros de Solis… On te doit tant. Alors pourquoi tout le monde ferme ses volets quand tu passes ?"
          }
        }
      }
    },
    "dialogue.act2.villager.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The elders speak of a voice beneath the forest. Don't listen to it, my boy. Promise me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les anciens parlent d'une voix sous la forêt. Ne l'écoute pas, mon garçon. Promets-le."
          }
        }
      }
    },
    "dialogue.act2.vision1.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This light... I've seen it before."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette lumière... je l'ai déjà vue."
          }
        }
      }
    },
    "dialogue.act2.vision1.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I saw a silhouette fall. Hands of black Aether."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'ai vu une silhouette tomber. Des mains d'Aether noir."
          }
        }
      }
    },
    "dialogue.act2.vision1.kael3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My hands."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mes mains."
          }
        }
      }
    },
    "dialogue.act2.vision1.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael? You're shaking."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael ? Tu trembles."
          }
        }
      }
    },
    "dialogue.act3.echo1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. Even the Void could not silence me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. Même le Vide n'a pas su me faire taire."
          }
        }
      }
    },
    "dialogue.act3.echo2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I am what remains: the echo it stole from me. The Threshold keeps everything it takes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je suis ce qu'il reste : l'écho qu'il m'a volé. Le Seuil garde tout ce qu'il prend."
          }
        }
      }
    },
    "dialogue.act3.echo3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You meant to cross that gate alone, with ITS voice in your head? Not while I still resound."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu comptais franchir cette porte seul, avec SA voix dans ta tête ? Pas tant que je résonne encore."
          }
        }
      }
    },
    "dialogue.act3.echo4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Behind you? In front, more like. You never could aim frost."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Derrière toi ? Devant, plutôt. Tu n'as jamais su viser la glace."
          }
        }
      }
    },
    "dialogue.act3.echoKael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyra?… No. You died. I watched you fall."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyra ?… Non. Tu es morte. Je t'ai vue tomber."
          }
        }
      }
    },
    "dialogue.act3.echoKael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "…Stay behind me, then. Like before."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "… Reste derrière moi, alors. Comme avant."
          }
        }
      }
    },
    "dialogue.act3.end1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Threshold fell silent."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Seuil s'est tu."
          }
        }
      }
    },
    "dialogue.act3.end2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The rest of Kael's story is coming soon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La suite de l'histoire d'Echoes of Aether arrive bientôt."
          }
        }
      }
    },
    "dialogue.act3.eran1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. I knew you would come."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. Je savais que tu viendrais."
          }
        }
      }
    },
    "dialogue.act3.eran2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Barely. The Threshold changed me. As it changes you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À peine. Le Seuil m'a changé. Comme il te change, toi."
          }
        }
      }
    },
    "dialogue.act3.eran3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Threshold waits. You must choose: disappear, or become."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Seuil attend. Tu dois choisir : disparaître ou devenir."
          }
        }
      }
    },
    "dialogue.act3.eran4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I crossed once. I came back wrong. The Threshold doesn't open a door. It rewrites whoever walks through."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je l'ai franchi une fois. J'en suis revenue brisée. Le Seuil n'ouvre pas une porte. Il réécrit celui qui le traverse."
          }
        }
      }
    },
    "dialogue.act3.eranChoice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I control the Aether."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je contrôle l'Aether."
          }
        }
      }
    },
    "dialogue.act3.eranChoice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Aether controls me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'Aether me contrôle."
          }
        }
      }
    },
    "dialogue.act3.eranChoicePrompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How do you answer Eran?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Que réponds-tu à Eran ?"
          }
        }
      }
    },
    "dialogue.act3.eranJoin1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I am already an echo, Kael. Let me finish what I began a century ago."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je suis déjà un écho, Kael. Laisse-moi finir ce que j'ai commencé il y a un siècle."
          }
        }
      }
    },
    "dialogue.act3.eranJoin2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Three voices against the Void. Works for me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trois voix contre le Vide. Ça me va."
          }
        }
      }
    },
    "dialogue.act3.eranResponse1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That is what my master said too. Before the end."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C'est ce que disait mon maître, aussi. Avant la fin."
          }
        }
      }
    },
    "dialogue.act3.eranResponse2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then you may be the first to understand what you have become."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors tu es peut-être le premier à comprendre ce que tu es devenu."
          }
        }
      }
    },
    "dialogue.act3.guardianEran1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Threshold defends itself, Kael. It wears the face of everything you buried."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Seuil se défend, Kael. Il porte le visage de tout ce que tu as enterré."
          }
        }
      }
    },
    "dialogue.act3.guardianEran2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Strike true, Kael. If your hand wavers, the Threshold will wear my face next."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Frappe juste, Kael. Si ta main tremble, le Seuil portera mon visage ensuite."
          }
        }
      }
    },
    "dialogue.act3.guardianKael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then I open it myself."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors je l'ouvrirai moi-même."
          }
        }
      }
    },
    "dialogue.act3.guardianPost1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's done. The way is open."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C'est fait. La voie est ouverte."
          }
        }
      }
    },
    "dialogue.act3.guardianPost2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Come, then. There is nothing left to hold you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Viens, alors. Plus rien ne te retient."
          }
        }
      }
    },
    "dialogue.act3.guardianVoice1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Strike it down. One last door between you and freedom."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Abats-le. Une dernière porte entre toi et la liberté."
          }
        }
      }
    },
    "dialogue.act3.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Who speaks? Show yourself."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Qui parle ? Montre-toi."
          }
        }
      }
    },
    "dialogue.act3.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Threshold. Lyra was right, this place is alive."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Seuil. Lyra avait raison, cet endroit est vivant."
          }
        }
      }
    },
    "dialogue.act3.kael2b": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then why does every step up sound like her footsteps behind me?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors pourquoi chaque marche que je gravis résonne comme ses pas derrière moi ?"
          }
        }
      }
    },
    "dialogue.act3.kael3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Eran? You're still alive."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eran ? Tu es encore en vie."
          }
        }
      }
    },
    "dialogue.act3.kael4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then let it rewrite me. There's little left worth keeping."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors qu'il me réécrive. Il ne reste plus grand-chose qui vaille d'être gardé."
          }
        }
      }
    },
    "dialogue.act3.resist1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No. Not like this. Not by forgetting why I came."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non. Pas comme ça. Pas en oubliant pourquoi je suis venu."
          }
        }
      }
    },
    "dialogue.act3.resist2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You refuse the power? After all that blood?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu refuses le pouvoir ? Après tout ce sang ?"
          }
        }
      }
    },
    "dialogue.act3.resist3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Power was never the point. I step back from the Threshold."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le pouvoir n'a jamais été le but. Je recule, loin du Seuil."
          }
        }
      }
    },
    "dialogue.act3.resist4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'll carry them awake. Lyra. Eran. Every name. That's the only echo worth keeping."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je les porterai éveillé. Lyra. Eran. Chaque nom. C'est le seul écho qui vaille d'être gardé."
          }
        }
      }
    },
    "dialogue.act3.resistEnd1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Threshold stayed shut. Kael turned his back on the Void."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Seuil resta clos. Kael tourna le dos au Vide."
          }
        }
      }
    },
    "dialogue.act3.resistEnd2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To carry the weight, awake. Perhaps that was the harder courage."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Porter le poids, lucide. C'était peut-être ça, le vrai courage."
          }
        }
      }
    },
    "dialogue.act3.resistEp.end": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "THE END — The Kept Echo. Thank you for playing."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "FIN — L'Écho gardé. Merci d'avoir joué."
          }
        }
      }
    },
    "dialogue.act3.resistEp.eran1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Someone must watch over the Threshold. I crossed once — I know what waits on the other side."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelqu'un doit veiller sur le Seuil. J'ai franchi une fois — je sais ce qui attend de l'autre côté."
          }
        }
      }
    },
    "dialogue.act3.resistEp.eran2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Go home, kid. Solis needs a living guardian. Not one more martyr."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rentre, gamin. Solis a besoin d'un gardien vivant. Pas d'un martyr de plus."
          }
        }
      }
    },
    "dialogue.act3.resistEp.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Farewell, Lyra. Your echo will haunt me no more. It will walk beside me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Adieu, Lyra. Ton écho ne me hantera plus. Il marchera à côté de moi."
          }
        }
      }
    },
    "dialogue.act3.resistEp.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The mark goes dark. For the first time since the forest… silence."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La marque s'éteint. Pour la première fois depuis la forêt… le silence."
          }
        }
      }
    },
    "dialogue.act3.resistEp.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You chose memory over power. Then I can fade… light at last."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu as choisi le souvenir plutôt que la puissance. Alors je peux partir… légère."
          }
        }
      }
    },
    "dialogue.act3.resistEp.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don't forget me, Kael. But don't live in my stead either. Live for yourself."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne m'oublie pas, Kael. Mais ne vis pas à ma place non plus. Vis pour toi."
          }
        }
      }
    },
    "dialogue.act3.resistEp.narr1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Seasons passed. The Forest of Echoes grew green again, slowly, scar after scar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des saisons passèrent. La Forêt des Échos reverdit, lentement, cicatrice après cicatrice."
          }
        }
      }
    },
    "dialogue.act3.resistEp.narr2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In Solis, they tell the story of a mark-bearer who refused to become a god."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À Solis, on raconte l'histoire d'un porteur de marque qui refusa de devenir un dieu."
          }
        }
      }
    },
    "dialogue.act3.resistEp.narr3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Threshold stayed sealed, watched by an old man who never quite sleeps."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Seuil resta clos, gardé par un vieil homme qui ne dort jamais tout à fait."
          }
        }
      }
    },
    "dialogue.act3.trueEnd1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyra. Eran. Everyone I burned to reach this step."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyra. Eran. Tous ceux que j'ai brûlés pour atteindre cette marche."
          }
        }
      }
    },
    "dialogue.act3.trueEnd2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step through. Become what the Aether always meant you to be."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Franchis le Seuil. Deviens ce que l'Aether a toujours voulu que tu sois."
          }
        }
      }
    },
    "dialogue.act3.trueEnd3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "…I'm sorry, Lyra. You were right. About all of it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "…Pardon, Lyra. Tu avais raison. Sur tout."
          }
        }
      }
    },
    "dialogue.act3.trueEnd4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "And then there was no one left to be sorry. Only the Threshold, and the thing that wore Kael's name."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Et puis il ne resta personne pour être désolé. Seulement le Seuil, et la chose qui portait le nom de Kael."
          }
        }
      }
    },
    "dialogue.act3.voice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You thought it was over. It was only the beginning."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu pensais que c'était fini. Ce n'était que le début."
          }
        }
      }
    },
    "dialogue.act3.voice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyra is gone. The Aether remains. And you? What remains of you?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyra est partie. L'Aether reste. Et toi, que reste-t-il ?"
          }
        }
      }
    },
    "dialogue.act3.voice3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You already know me, Kael. I am what you refuse to see."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu me connais déjà, Kael. Je suis ce que tu refuses de voir."
          }
        }
      }
    },
    "dialogue.act3.voice4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Alive, yes. It feeds on what you carry. Let it take the grief, and you'll feel nothing at all."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vivant, oui. Il se nourrit de ce que tu portes. Laisse-le prendre le chagrin, et tu ne sentiras plus rien."
          }
        }
      }
    },
    "dialogue.act3.voiceName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Voice"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La Voix"
          }
        }
      }
    },
    "dialogue.act4.avatarPost1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible… I am… eternal…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible… je suis… éternel…"
          }
        }
      }
    },
    "dialogue.act4.avatarPost2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Avatar dissolves. Only the Heart remains, defenseless."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'Avatar se dissout. Il ne reste que le Cœur, sans défense."
          }
        }
      }
    },
    "dialogue.act4.avatarPost3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It is time. What I do now, no one can undo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C'est l'heure. Ce que je fais maintenant, personne ne pourra le défaire."
          }
        }
      }
    },
    "dialogue.act4.avatarPre1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I am every shadow you defeated. Every echo you failed to save. Behold your work."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je suis chaque ombre que tu as vaincue. Chaque écho que tu n'as pas sauvé. Regarde ton œuvre."
          }
        }
      }
    },
    "dialogue.act4.avatarPre2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don't listen! We are three. It is only what remains."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne l'écoute pas ! Nous sommes trois. Lui n'est que le reste."
          }
        }
      }
    },
    "dialogue.act4.avatarPre3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For Solis. For Lyra. For the end of the stolen echoes!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour Solis. Pour Lyra. Pour la fin des échos volés !"
          }
        }
      }
    },
    "dialogue.act4.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Destroy it. Free the echoes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le détruire. Libérer les échos."
          }
        }
      }
    },
    "dialogue.act4.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Merge with it. Become the keeper."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fusionner. Devenir le gardien."
          }
        }
      }
    },
    "dialogue.act4.choicePrompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What will Kael do with the Heart?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Que fera Kael du Cœur ?"
          }
        }
      }
    },
    "dialogue.act4.choiceResponse1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then Lyra will be free too… even if it means goodbye."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors Lyra sera libre aussi… même si cela veut dire adieu."
          }
        }
      }
    },
    "dialogue.act4.choiceResponse2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "At last. A bearer worthy of me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enfin. Un porteur digne de moi."
          }
        }
      }
    },
    "dialogue.act4.confront1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Here you stand before me at last. Do you know what I am, Kael?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Te voilà enfin devant moi. Sais-tu ce que je suis, Kael ?"
          }
        }
      }
    },
    "dialogue.act4.confront2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The voice that promised me strength. The one that took Lyra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La voix qui m'a promis la force. Celle qui a pris Lyra."
          }
        }
      }
    },
    "dialogue.act4.confront3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I am the Heart. Every echo, every memory, every death… all returns to me. Without me, everything scatters."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je suis le Cœur. Chaque écho, chaque souvenir, chaque mort… tout revient à moi. Sans moi, tout se disperse."
          }
        }
      }
    },
    "dialogue.act4.confront4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It half-lies, Kael. That is worse than a lie. Choose with your eyes open."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il ment à moitié, Kael. C'est pire qu'un mensonge. Choisis avec les yeux ouverts."
          }
        }
      }
    },
    "dialogue.act4.confront5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Whatever you choose… you must defeat me first. Come."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quoi que tu choisisses… il te faudra d'abord me vaincre. Viens."
          }
        }
      }
    },
    "dialogue.act4.destroy1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I made my promise before the Voice. I keep it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'ai fait ma promesse devant la Voix. Je la tiens."
          }
        }
      }
    },
    "dialogue.act4.destroy2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael… if you shatter it, I go with the others. You know that."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael… si tu le brises, je pars avec les autres. Tu le sais."
          }
        }
      }
    },
    "dialogue.act4.destroy3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I know. And that is why I do it. You deserve to be free, not to be my echo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je sais. Et c'est pour ça que je le fais. Tu mérites d'être libre, pas d'être mon écho."
          }
        }
      }
    },
    "dialogue.act4.destroy4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then… thank you. For the forest, for the Threshold, for everything. Farewell, Kael of Solis."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors… merci. Pour la forêt, pour le Seuil, pour tout. Adieu, Kael de Solis."
          }
        }
      }
    },
    "dialogue.act4.destroy5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Farewell, Lyra. May your echo become a song."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Adieu, Lyra. Que ton écho devienne chanson."
          }
        }
      }
    },
    "dialogue.act4.destroyEnd1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Heart shatters. One by one, the echoes rise — free, at last. The Aether becomes light again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Cœur se brise. Un à un, les échos s'élèvent — libres, enfin. L'Aether redevient lumière."
          }
        }
      }
    },
    "dialogue.act4.destroyEnd2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then, within the light, Kael watches the last echo rise. It wears his face."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors, dans la lumière, Kael voit le dernier écho se lever. Il porte son visage."
          }
        }
      }
    },
    "dialogue.act4.destroyEnd3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No one returns from the shrine. What walks toward Solis, empty-handed and at peace, only remembers having been Kael."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Personne ne revient du sanctuaire. Ce qui marche vers Solis, les mains vides et le cœur en paix, se souvient seulement d'avoir été Kael."
          }
        }
      }
    },
    "dialogue.act4.devourers1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Careful! Those things feed on echoes… they are looking at me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attention ! Ces choses se nourrissent des échos… ils me regardent."
          }
        }
      }
    },
    "dialogue.act4.devourers2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nothing devours you while I still stand. On your guard!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Personne ne te dévorera tant que je tiens debout. En garde !"
          }
        }
      }
    },
    "dialogue.act4.echo1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I feel it too. Every echo comes from here. So do I."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je le sens aussi. Tous les échos viennent d'ici. Moi aussi."
          }
        }
      }
    },
    "dialogue.act4.eran1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fifty years I searched for this hall. It is more terrible than in my dreams."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cinquante ans que je cherche cette salle. Elle est plus terrible que dans mes rêves."
          }
        }
      }
    },
    "dialogue.act4.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This place… it beats. Like a heart."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce lieu… il bat. Comme un cœur."
          }
        }
      }
    },
    "dialogue.act4.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then let's end this. For Lyra. For all the others."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors finissons-en. Pour Lyra. Pour tous les autres."
          }
        }
      }
    },
    "dialogue.act4.memoriesDone1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You faced them, Kael. All of them. That is what it means to be whole."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu les as regardés en face, Kael. Tous. C'est ça, être entier."
          }
        }
      }
    },
    "dialogue.act4.memoriesDone2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Void wanted me to forget. I remember. That is my strength."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Vide voulait me faire oublier. Je me souviens. C'est ma force."
          }
        }
      }
    },
    "dialogue.act4.memory.1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Solis, one summer morning. A wooden house, the smell of bread. A voice calls: “Kael, you'll be late!”"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Solis, un matin d'été. Une maison de bois, l'odeur du pain. Une voix appelle : « Kael, tu vas être en retard ! »"
          }
        }
      }
    },
    "dialogue.act4.memory.1Kael": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mother… I had forgotten her voice."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ma mère… J'avais oublié sa voix."
          }
        }
      }
    },
    "dialogue.act4.memory.2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The village square. Lyra laughs, hands full of Aether shards. “One day I'll see what lies beyond the forest.”"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La place du village. Lyra rit, des éclats d'Aether plein les mains. « Un jour, je verrai ce qu'il y a derrière la forêt. »"
          }
        }
      }
    },
    "dialogue.act4.memory.2Kael": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "She saw what lay beyond. Because of me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Elle l'a vu, ce qu'il y avait derrière. À cause de moi."
          }
        }
      }
    },
    "dialogue.act4.memory.3": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The shrine. A hand reaching for the red light. A voice whispers: “Accept, and you will never be weak again.”"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le sanctuaire. Une main tendue vers la lumière rouge. Une voix murmure : « Accepte, et plus jamais tu ne seras faible. »"
          }
        }
      }
    },
    "dialogue.act4.memory.3Kael": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The pact. That is where everything fell apart. I will not run from this memory again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le pacte. C'est là que tout a basculé. Je ne fuirai plus ce souvenir."
          }
        }
      }
    },
    "dialogue.act4.memoryName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Memory"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Souvenir"
          }
        }
      }
    },
    "dialogue.act4.merge1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Void needs a keeper. Someone who remembers every face. It will be me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Vide a besoin d'un gardien. Quelqu'un qui se souvient de chaque visage. Ce sera moi."
          }
        }
      }
    },
    "dialogue.act4.merge2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael, no! It is the same trap that took my fifty years!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael, non ! C'est le même piège qui m'a pris cinquante ans !"
          }
        }
      }
    },
    "dialogue.act4.merge3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No, Eran. You sought power. I keep watch. It is different — I choose to believe it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non, Eran. Toi, tu voulais le pouvoir. Moi, je veille. C'est différent — je veux le croire."
          }
        }
      }
    },
    "dialogue.act4.merge4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then I stay with you. An echo beside the keeper. No one keeps watch alone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors je reste avec toi. Un écho auprès du gardien. Personne ne veille seul."
          }
        }
      }
    },
    "dialogue.act4.merge5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Together, then. May no echo ever be stolen again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ensemble, alors. Que plus aucun écho ne soit volé."
          }
        }
      }
    },
    "dialogue.act4.mergeEnd1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Heart still beats — but it beats differently now. Calm. Watchful. Almost human."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Cœur bat toujours — mais il bat autrement. Calme. Attentif. Presque humain."
          }
        }
      }
    },
    "dialogue.act4.mergeEnd2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Years later, at the shrine, a young man kneels before the red light. He has lost someone. He wants to be strong."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des années plus tard, au sanctuaire, un jeune homme s'agenouille devant la lumière rouge. Il a perdu quelqu'un. Il veut être fort."
          }
        }
      }
    },
    "dialogue.act4.mergeEnd3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "And the Heart whispers, with Kael's voice: “Accept, and you will never be weak again.”"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Et le Cœur murmure, avec la voix de Kael : « Accepte, et plus jamais tu ne seras faible. »"
          }
        }
      }
    },
    "dialogue.act4.reflection.elder1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I kept the village gate all my life… then the Void took me. Who keeps the gate now?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'ai gardé la porte du village toute ma vie… puis le Vide m'a pris. Qui garde la porte, maintenant ?"
          }
        }
      }
    },
    "dialogue.act4.reflection.elder2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dorin… yes. Then I can rest. Thank you, lad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dorin… oui. Alors je peux me reposer. Merci, petit."
          }
        }
      }
    },
    "dialogue.act4.reflection.elderKael": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The gate holds, elder. Dorin keeps watch. You can let go."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La porte tient, doyen. Dorin veille. Vous pouvez lâcher prise."
          }
        }
      }
    },
    "dialogue.act4.reflection.elderName": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reflection of the Elder"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reflet du doyen"
          }
        }
      }
    },
    "dialogue.act4.reflection.lost1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I got lost in the forest… mama must be looking for me. It's so dark here."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je me suis perdu dans la forêt… maman doit me chercher. Il fait si sombre ici."
          }
        }
      }
    },
    "dialogue.act4.reflection.lost2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I see her! Mama! Thank you, mister…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je la vois ! Maman ! Merci, monsieur…"
          }
        }
      }
    },
    "dialogue.act4.reflection.lostKael": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your mother waits on the other side, little one. Follow the light. Don't be afraid."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta mère t'attend de l'autre côté, petit. Suis la lumière. N'aie pas peur."
          }
        }
      }
    },
    "dialogue.act4.reflection.lostName": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reflection of the Child"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reflet de l'enfant"
          }
        }
      }
    },
    "dialogue.act4.reflection.smith1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My forge… I still hear the hammer. I promised a blade to the boy from Solis."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ma forge… j'entends encore le marteau. J'avais promis une lame au garçon de Solis."
          }
        }
      }
    },
    "dialogue.act4.reflection.smith2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then the fire may die down. Farewell, blade-bearer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors le feu peut s'éteindre. Adieu, porteur de lame."
          }
        }
      }
    },
    "dialogue.act4.reflection.smithKael": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The blade was forged. It carried me all the way here. Your promise is kept."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La lame a été forgée. Elle m'a mené jusqu'ici. Votre promesse est tenue."
          }
        }
      }
    },
    "dialogue.act4.reflection.smithName": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reflection of the Smith"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reflet du forgeron"
          }
        }
      }
    },
    "dialogue.act4.reflectionsDone1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Three faces returned to peace. The Void weakens — I can feel it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trois visages rendus à la paix. Le Vide s'affaiblit, je le sens."
          }
        }
      }
    },
    "dialogue.act4.reflectionsDone2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every freed echo is one more light against it. Let's press on."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque écho libéré est une lumière de plus contre lui. Continuons."
          }
        }
      }
    },
    "dialogue.act4.voice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome home, Kael. Here, everything begins. Here, everything ends."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bienvenue chez toi, Kael. Ici, tout commence. Ici, tout finit."
          }
        }
      }
    },
    "dialogue.act4.voice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Come closer. The Heart waits for you alone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Approche. Le Cœur n'attend plus que toi."
          }
        }
      }
    },
    "dialogue.aether.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's temporary. It always fades."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C'est temporaire. Ça passe toujours."
          }
        }
      }
    },
    "dialogue.aether.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Would you have preferred I let it kill you?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu aurais préféré que je la laisse te tuer ?"
          }
        }
      }
    },
    "dialogue.aether.choice3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I don't control this power yet. But it obeys me. That's enough."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne contrôle pas encore ce pouvoir. Mais il m'obéit. C'est suffisant."
          }
        }
      }
    },
    "dialogue.aether.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Whatever worked. The creature is dead."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce qui marchait. La créature est morte."
          }
        }
      }
    },
    "dialogue.aether.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I know. You want me to promise not to use it. But I don't make promises I can't keep."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je sais. Tu veux que je promette de ne pas m'en servir. Mais je ne fais pas de promesses que je ne peux pas tenir."
          }
        }
      }
    },
    "dialogue.aether.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... What was that? When you struck, the air turned black. I felt the cold down to my bones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... Qu'est-ce que c'était ? Quand tu as frappé, l'air est devenu noir. J'ai senti le froid jusque dans mes os."
          }
        }
      }
    },
    "dialogue.aether.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dead, yes. But your hand is still shaking. And your veins... look. They're black, Kael."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Morte, oui. Mais ta main tremble encore. Et tes veines... regarde. Elles sont noires, Kael."
          }
        }
      }
    },
    "dialogue.aether.lyra3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The sanctuary is further ahead. If anything can explain your mark, it's there. But Kael..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le sanctuaire est plus loin. Si quelque chose peut expliquer ta marque, c'est là-bas. Mais Kael..."
          }
        }
      }
    },
    "dialogue.aether.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Facing Lyra's fear"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Face à la peur de Lyra"
          }
        }
      }
    },
    "dialogue.aether.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Always\"? How long have you been doing this, Kael?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Toujours » ? Depuis combien de temps tu fais ça, Kael ?"
          }
        }
      }
    },
    "dialogue.aether.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No. But there's a difference between fighting and... what you did at the end."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non. Mais il y a une différence entre se battre et... ce que tu as fait à la fin."
          }
        }
      }
    },
    "dialogue.aether.response3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"It obeys me.\" Do you hear yourself? You sound like you're talking about a wild animal, not a part of you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Il m'obéit. » Tu t'entends ? On dirait que tu parles d'un animal sauvage, pas d'une partie de toi."
          }
        }
      }
    },
    "dialogue.boss.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We're not afraid of you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous n'avons pas peur de toi."
          }
        }
      }
    },
    "dialogue.boss.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What happened to this sanctuary?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Qu'est-il arrivé à ce sanctuaire ?"
          }
        }
      }
    },
    "dialogue.boss.guardianName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cracked Guardian"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardien fissuré"
          }
        }
      }
    },
    "dialogue.boss.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can feel its power… This mark on my arm is burning."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je sens sa puissance… Cette marque sur mon bras brûle."
          }
        }
      }
    },
    "dialogue.boss.post.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An Aether Core… The source of its power. I can feel the energy radiating from it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un Cœur d'Aether… La source de sa puissance. Je peux sentir l'énergie qui en émane."
          }
        }
      }
    },
    "dialogue.boss.post.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "… Its resonance is so dark. Like an echo of something ancient and terrible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "… Sa résonance est si sombre. Comme un écho de quelque chose d'ancien et de terrible."
          }
        }
      }
    },
    "dialogue.boss.post.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "He… he's defeated. Kael, look! Something is glowing in the rubble."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il… il est vaincu. Kael, regarde ! Quelque chose brille dans les décombres."
          }
        }
      }
    },
    "dialogue.boss.post.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take it. We'll need it to understand what's corrupting these lands."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prends-le. Nous en aurons besoin pour comprendre ce qui corrompt ces terres."
          }
        }
      }
    },
    "dialogue.boss.pre1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insolent mortals… You dare defile this sanctuary with your presence."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mortels impudents… Vous osez souiller ce sanctuaire de votre présence."
          }
        }
      }
    },
    "dialogue.boss.pre2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Black Aether gave me a power beyond your comprehension. Kneel… or perish."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'Aether noir m'a donné une force que vous ne pouvez concevoir. Agenouillez-vous… ou périssez."
          }
        }
      }
    },
    "dialogue.boss.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How do you respond to the Guardian?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comment répondre au Gardien ?"
          }
        }
      }
    },
    "dialogue.boss.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then you are even more foolish than I thought. So be it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors vous êtes encore plus fous que je ne le pensais. Qu'il en soit ainsi."
          }
        }
      }
    },
    "dialogue.boss.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This place was sacred. The Black Aether consumed it… as it will consume me. But not before it destroys you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce lieu était sacré. L'Aether noir l'a consumé… comme il me consumera. Mais pas avant de vous détruire."
          }
        }
      }
    },
    "dialogue.bram.bram1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hey, you! You've got a fighter's look. I've got just what you need."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hé, toi ! T'as une tête de combattant. J'ai exactement ce qu'il te faut."
          }
        }
      }
    },
    "dialogue.bram.bram2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My forge has been running thirty years. Every blade I made outlasted its owner. That says it all."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ma forge tourne depuis trente ans. Chaque lame que j'ai faite a survécu à son propriétaire. Ça dit tout."
          }
        }
      }
    },
    "dialogue.bram.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I need a solid weapon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je cherche une arme solide."
          }
        }
      }
    },
    "dialogue.bram.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Just browsing."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je veux juste regarder."
          }
        }
      }
    },
    "dialogue.bram.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show me what you've got."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Montre-moi ce que tu as."
          }
        }
      }
    },
    "dialogue.bram.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then you're in the right place. Iron, runic, everything you need to survive out there. Take a look."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors t'es au bon endroit. Du fer, du runique, tout ce qu'il faut pour survivre là-dehors. Regarde."
          }
        }
      }
    },
    "dialogue.bram.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No problem. Come back when you've got gold. Quality has a price."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas de problème. Reviens quand t'as des pièces d'or. La qualité a un prix."
          }
        }
      }
    },
    "dialogue.child.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A little curiosity is good."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un peu de curiosité, c'est bien."
          }
        }
      }
    },
    "dialogue.child.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You need to stay safe."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu dois rester à l'abri."
          }
        }
      }
    },
    "dialogue.child.line1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hey! You don't look like you're from the village. Are you an adventurer?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hé ! T'as pas l'air d'être du village. T'es un aventurier ?"
          }
        }
      }
    },
    "dialogue.child.line2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My dad says not to go near the forest. But I saw a black light in there last night!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mon père dit de pas s'approcher de la forêt. Mais j'ai vu une lumière noire là-dedans hier soir !"
          }
        }
      }
    },
    "dialogue.child.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Child"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enfant"
          }
        }
      }
    },
    "dialogue.child.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you scared?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu as peur ?"
          }
        }
      }
    },
    "dialogue.child.quest.active1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Did you find it? My bear? He's in the forest, to the right…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu l'as trouvé ? Mon ours ? Il est dans la forêt, vers la droite…"
          }
        }
      }
    },
    "dialogue.child.quest.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'll find it, I promise."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je le retrouverai, promis."
          }
        }
      }
    },
    "dialogue.child.quest.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The forest is dangerous…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La forêt est dangereuse…"
          }
        }
      }
    },
    "dialogue.child.quest.done1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You found my bear! You're the best hero in the whole wide world!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu as retrouvé mon ours ! Tu es le meilleur héros du monde entier !"
          }
        }
      }
    },
    "dialogue.child.quest.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Look for the toy?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chercher le jouet ?"
          }
        }
      }
    },
    "dialogue.child.quest.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thank you thank you thank you! It's a wooden bear with a red ribbon!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merci merci merci ! C'est un ours en bois avec un ruban rouge !"
          }
        }
      }
    },
    "dialogue.child.quest.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please… He's my only friend since mom left…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S'il te plaît… C'est mon seul ami depuis que maman est partie…"
          }
        }
      }
    },
    "dialogue.child.quest1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mister… Mister! My little wooden bear… I lost it when the shadows came."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Monsieur… Monsieur ! Mon petit ours en bois… je l'ai perdu quand les ombres sont venues."
          }
        }
      }
    },
    "dialogue.child.quest2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I think it fell in the forest, near the big tree on the right. Could you find it?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je crois qu'il est tombé dans la forêt, près du gros arbre à droite. Tu pourrais le retrouver ?"
          }
        }
      }
    },
    "dialogue.child.real.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mom says I'm not supposed to talk to you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maman dit que je dois pas te parler."
          }
        }
      }
    },
    "dialogue.child.real.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "But your hand glows sometimes. I saw it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mais ta main elle brille parfois. J'ai vu."
          }
        }
      }
    },
    "dialogue.child.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeah! I want to be like you, a real warrior with powers!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouais ! Je veux devenir comme toi, un vrai guerrier avec des pouvoirs !"
          }
        }
      }
    },
    "dialogue.child.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I know... but it's so boring here. Is it true you have magic powers?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je sais... mais c'est tellement ennuyeux ici. C'est vrai que t'as des pouvoirs magiques ?"
          }
        }
      }
    },
    "dialogue.chooseResponse": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose how Kael responds."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisis comment Kael répond."
          }
        }
      }
    },
    "dialogue.desert.ambush.kael1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An ambush! They rise from the dunes!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une embuscade ! Ils surgissent des dunes !"
          }
        }
      }
    },
    "dialogue.desert.boss.post1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The colossus returns to the sand. The desert breathes again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le colosse retourne au sable. Le désert respire à nouveau."
          }
        }
      }
    },
    "dialogue.desert.boss.post2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The caravans can pass again. If any remain."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les caravanes pourront repasser. S’il en reste."
          }
        }
      }
    },
    "dialogue.desert.boss.pre1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The ground is shaking. Something huge sleeps beneath the dunes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le sol tremble. Quelque chose d’énorme dort sous les dunes."
          }
        }
      }
    },
    "dialogue.desert.boss.pre2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Too late to turn back."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trop tard pour reculer."
          }
        }
      }
    },
    "dialogue.desert.chest.kael1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A chest buried in the sand. The raiders never found it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un coffre enfoui sous le sable. Les pillards ne l’ont jamais trouvé."
          }
        }
      }
    },
    "dialogue.desert.combat1.kael1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Caravan raiders. They won’t rob anyone again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des pillards de caravanes. Ils ne détrousseront plus personne."
          }
        }
      }
    },
    "dialogue.desert.enter.kael1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ossara. The sun strikes like a hammer. Even the wind is thirsty."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ossara. Le soleil frappe comme un marteau. Même le vent a soif."
          }
        }
      }
    },
    "dialogue.desert.enter.kael2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Raider tracks in the sand. I’m not alone out here."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des traces de pillards dans le sable. Je ne suis pas seul ici."
          }
        }
      }
    },
    "dialogue.desert.oasis.kael1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear water. My strength returns."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "De l’eau claire. Mes forces reviennent."
          }
        }
      }
    },
    "dialogue.dorin.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stare at the mark in silence."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Regarder la marque en silence."
          }
        }
      }
    },
    "dialogue.dorin.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your dead aren't my problem. I'm looking for my own answers."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos morts ne me regardent pas. Je cherche mes propres réponses."
          }
        }
      }
    },
    "dialogue.dorin.choice3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If this mark can destroy what took them... then show me the way."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si cette marque peut détruire ce qui les a pris... alors montrez-moi le chemin."
          }
        }
      }
    },
    "dialogue.dorin.dorin1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "So you're the one. The one Lyra picked up on the road. With the mark that worries my guards."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors c'est toi. Celui que Lyra a ramassé sur le chemin. Avec la marque qui inquiète mes gardes."
          }
        }
      }
    },
    "dialogue.dorin.dorin2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Three scouts. Gone. The forest reeks of corruption. And you show up with a hand that glows like the creatures that took them. So I'll be direct."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trois éclaireurs. Disparus. La forêt pue la corruption. Et toi, tu débarques avec une main qui brille comme les créatures qui les ont pris. Alors je vais être direct."
          }
        }
      }
    },
    "dialogue.dorin.dorin3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The forest edge is to the north. Come back alive and we'll talk about trust. Don't come back... well, problem solved."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La lisière est au nord. Si tu reviens vivant, on reparlera de confiance. Si tu ne reviens pas... eh bien, problème réglé."
          }
        }
      }
    },
    "dialogue.dorin.lyra1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dorin, he doesn't even know where he's from. Give him a chance."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dorin, il ne sait même pas d'où il vient. Laisse-lui une chance."
          }
        }
      }
    },
    "dialogue.dorin.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm coming with you. Not to protect you. To make sure your mark doesn't end up consuming you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je viens avec toi. Pas pour te protéger. Pour m'assurer que ta marque ne finisse pas par te consumer."
          }
        }
      }
    },
    "dialogue.dorin.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reply to Dorin"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Répondre à Dorin"
          }
        }
      }
    },
    "dialogue.dorin.real.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You walk around like you're looking for something."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu te promènes comme si tu cherchais quelque chose."
          }
        }
      }
    },
    "dialogue.dorin.real.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm looking for what I lost."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je cherche ce que j'ai perdu."
          }
        }
      }
    },
    "dialogue.dorin.real.3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your memories. Lyra told us."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tes souvenirs. Lyra nous a dit."
          }
        }
      }
    },
    "dialogue.dorin.real.4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Things have been coming from the north for weeks. Corrupted animals. Dead trees. The Cendreval mines have gone silent. People are disappearing."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il y a des choses qui viennent du nord depuis des semaines. Des animaux corrompus. Des arbres morts. Les mines de Cendreval ne répondent plus. Les gens disparaissent."
          }
        }
      }
    },
    "dialogue.dorin.real.5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "And you're telling me this because..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Et tu me racontes ça parce que..."
          }
        }
      }
    },
    "dialogue.dorin.real.6": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Because of that mark on your hand... my father spoke of it. He said the Guardians bore that sign. And the Guardians were the only ones who could touch corrupted Aether without dying."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parce que cette marque sur ta main... mon père en parlait. Il disait que les Gardiens portaient ce signe. Et les Gardiens étaient les seuls à pouvoir toucher l'Aether corrompu sans mourir."
          }
        }
      }
    },
    "dialogue.dorin.real.7": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Maybe your father was wrong."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton père se trompait peut-être."
          }
        }
      }
    },
    "dialogue.dorin.real.8": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Maybe. But you're alive. And you came from the north."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Peut-être. Mais toi tu es vivant. Et tu viens du nord."
          }
        }
      }
    },
    "dialogue.dorin.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Even your silence feels threatening. But the monsters out there don't stay quiet."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Même ton silence a quelque chose de menaçant. Mais les monstres, eux, ne se taisent pas."
          }
        }
      }
    },
    "dialogue.dorin.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your answers are to the north, Kael. Whether you like it or not, your paths lead to the same place."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tes réponses sont au nord, Kael. Que tu le veuilles ou non, vos chemins mènent au même endroit."
          }
        }
      }
    },
    "dialogue.dorin.response3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Courage or recklessness. Either way, it suits me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Du courage ou de l'inconscience. Dans les deux cas, ça m'arrange."
          }
        }
      }
    },
    "dialogue.echo.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyra's Echo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Écho de Lyra"
          }
        }
      }
    },
    "dialogue.finale.eran.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You... came back."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu es... revenu."
          }
        }
      }
    },
    "dialogue.finale.eran.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I do."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Moi, je sais."
          }
        }
      }
    },
    "dialogue.finale.eran.3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I told you to run. I sealed your memory myself. So you would survive."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je t'ai dit de fuir. J'ai scellé ta mémoire moi-même. Pour que tu survives."
          }
        }
      }
    },
    "dialogue.finale.eran.4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're... stronger than I thought. Or more desperate."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu es... plus fort que je ne pensais. Ou plus désespéré."
          }
        }
      }
    },
    "dialogue.finale.eran.5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Because if I left, the corruption would spread. I held the seal for twenty years, Kael. Twenty years alone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parce que si je partais, la corruption se répandait. J'ai tenu le sceau vingt ans, Kael. Vingt ans seul."
          }
        }
      }
    },
    "dialogue.finale.eran.6": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I was waiting for you. I hoped you'd return with your memory. That you could... replace the seal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je t'attendais. J'espérais que tu reviendrais avec ta mémoire. Que tu pourrais... remplacer le sceau."
          }
        }
      }
    },
    "dialogue.finale.eran.7": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't need your memories. The blood of the Guardians knows. Lay your hand on the crystal. Your Aether will do the rest."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu n'as pas besoin de tes souvenirs. Le sang des Gardiens sait. Pose ta main sur le cristal. Ton Aether fera le reste."
          }
        }
      }
    },
    "dialogue.finale.kael.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I have no memories, Eran. I don't know why I left."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je n'ai pas de souvenirs, Eran. Je ne sais pas pourquoi je suis parti."
          }
        }
      }
    },
    "dialogue.finale.kael.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm not here to die."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne suis pas là pour mourir."
          }
        }
      }
    },
    "dialogue.finale.kael.3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Why didn't you run too? Why stay here, burning yourself away?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pourquoi tu n'as pas fui toi aussi ? Pourquoi rester ici à te consumer ?"
          }
        }
      }
    },
    "dialogue.finale.voice.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "And now you've come back to die like the others."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Et maintenant tu es revenu mourir comme les autres."
          }
        }
      }
    },
    "dialogue.finale.voice.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are here to END."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu es là pour FINIR."
          }
        }
      }
    },
    "dialogue.forest.exit.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My mark is burning. Like it's being pulled forward."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ma marque brûle. Comme si elle était attirée vers l'avant."
          }
        }
      }
    },
    "dialogue.forest.exit.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This path... the energy is different here. Denser. Older. We're getting close to something."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce sentier... l'énergie est différente ici. Plus dense. Plus ancienne. On approche de quelque chose."
          }
        }
      }
    },
    "dialogue.forest.exit.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then let's go. Whatever's at the end of this path... we need to know."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors allons-y. Quoi qu'il y ait au bout de ce chemin... on doit savoir."
          }
        }
      }
    },
    "dialogue.forest.grove.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can control this power."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je contrôle ce pouvoir."
          }
        }
      }
    },
    "dialogue.forest.grove.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It scares me too."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ça me fait peur aussi."
          }
        }
      }
    },
    "dialogue.forest.grove.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I felt it. When I hit it... it's like the Aether responded inside me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je l'ai senti. Quand je l'ai frappée... c'est comme si l'Aether répondait en moi."
          }
        }
      }
    },
    "dialogue.forest.grove.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... that creature. It was corrupted by black Aether. Did you see its eyes? Just like your mark."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... cette créature. Elle était corrompue par l'Aether noir. Tu as vu ses yeux ? Exactement comme ta marque."
          }
        }
      }
    },
    "dialogue.forest.grove.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The clearing further east... the air is heavier there. Stay alert."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La clairière plus à l'est... l'air y est plus lourd. Reste sur tes gardes."
          }
        }
      }
    },
    "dialogue.forest.grove.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What does that mean?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Qu'est-ce que ça veut dire ?"
          }
        }
      }
    },
    "dialogue.forest.grove.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Or it controls you. The more you use it, the stronger it gets. We need to understand where it comes from."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ou c'est lui qui te contrôle. Plus tu t'en sers, plus il grandit. Il faut qu'on comprenne d'où il vient."
          }
        }
      }
    },
    "dialogue.forest.grove.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "At least you're honest. That's good. Let's keep going, there's something else ahead. I can feel it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Au moins tu es honnête. C'est bien. Continuons, il y a autre chose plus loin. Je le sens."
          }
        }
      }
    },
    "dialogue.forest.real.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My father used to say this forest sang at night. The villagers called it the whispers of the Aether."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mon père disait que cette forêt chantait la nuit. Les gens du village appelaient ça les murmures de l'Aether."
          }
        }
      }
    },
    "dialogue.forest.real.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It doesn't sing anymore."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Elle ne chante plus."
          }
        }
      }
    },
    "dialogue.forest.real.3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non."
          }
        }
      }
    },
    "dialogue.forest.real.4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Do you feel anything? With your mark?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu ressens quelque chose ? Avec ta marque ?"
          }
        }
      }
    },
    "dialogue.forest.real.5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something passed through here. Recently. And it came from the north."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelque chose est passé par ici. Récemment. Et ça venait du nord."
          }
        }
      }
    },
    "dialogue.forest.toy.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A small wooden bear… It's the village child's toy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un petit ours en bois… C'est le jouet de l'enfant du village."
          }
        }
      }
    },
    "dialogue.forest.toy.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Poor little one. At least we can return it when we pass through the village again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pauvre petit. Au moins on pourra lui rendre quand on repassera au village."
          }
        }
      }
    },
    "dialogue.garen.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm a fighter, I can handle it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je suis un combattant, je peux gérer."
          }
        }
      }
    },
    "dialogue.garen.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Understood. I'll come back."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je comprends. Je repasserai."
          }
        }
      }
    },
    "dialogue.garen.delivery1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mara's package! Finally. You were quick."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le colis de Mara ! Enfin. T'as fait ça vite."
          }
        }
      }
    },
    "dialogue.garen.delivery2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take this, you earned it. And tell her to send a real messenger next time."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prends ça, c'est mérité. Et dis-lui qu'elle peut envoyer un vrai messager la prochaine fois."
          }
        }
      }
    },
    "dialogue.garen.done1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All sorted. If you want to head north, talk to Dorin. He's the one who decides."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout est en ordre. Si tu veux partir vers le nord, parle à Dorin. C'est lui qui décide."
          }
        }
      }
    },
    "dialogue.garen.first1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stop. The north gate is closed by order of the village elder."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte. La porte nord est fermée sur ordre du chef du village."
          }
        }
      }
    },
    "dialogue.garen.first2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The forest has been infested for two weeks. Nobody gets through. Either way."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La forêt est infestée depuis deux semaines. Personne ne passe. Dans aucun sens."
          }
        }
      }
    },
    "dialogue.garen.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No exceptions?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il n'y a aucune exception ?"
          }
        }
      }
    },
    "dialogue.garen.real.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No one's keeping you here. But if you come back with trouble on your heels... you keep walking."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "On ne vous retient pas. Mais si vous revenez avec des problèmes dans les pattes... vous continuez sans vous arrêter."
          }
        }
      }
    },
    "dialogue.garen.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm sure you can. But orders are orders. If you want out this way, talk to Dorin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'en suis sûr. Mais les ordres sont les ordres. Pour partir par ici, parle à Dorin."
          }
        }
      }
    },
    "dialogue.garen.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wise choice. By the way, if you run into Mara the herbalist, she has something for me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sage décision. Au fait, si tu croises Mara l'herboriste, elle a quelque chose pour moi."
          }
        }
      }
    },
    "dialogue.kael": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael"
          }
        }
      }
    },
    "dialogue.lore.arch.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The last time I saw that mark was twenty years ago. The day the Guardians disappeared."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La dernière fois que j'ai vu cette marque, c'était il y a vingt ans. Le jour où les Gardiens ont disparu."
          }
        }
      }
    },
    "dialogue.lore.arch.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some. Not all. Eran, the First Guardian, survived. He tried to seal the source of the corruption alone, beyond the Threshold."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Certains. Pas tous. Eran, le Premier Gardien, a survécu. Il a voulu sceller la source de la corruption seul, au-delà du Seuil."
          }
        }
      }
    },
    "dialogue.lore.arch.3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What awaits you there... is him. Or what he has become."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce qui t'attend là-bas... c'est lui. Ou ce qu'il est devenu."
          }
        }
      }
    },
    "dialogue.lore.arch.4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Guardian who absorbs too much corrupted Aether without an anchor... yes. The anchor is the bond with the other Guardians."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un Gardien qui absorbe trop d'Aether corrompu sans ancrage... oui. L'ancrage, c'est le lien avec les autres Gardiens."
          }
        }
      }
    },
    "dialogue.lore.arch.5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "He said he would stay. That he would wait."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il a dit qu'il resterait. Qu'il attendrait."
          }
        }
      }
    },
    "dialogue.lore.kael.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are they dead?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ils sont morts ?"
          }
        }
      }
    },
    "dialogue.lore.kael.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then I have no anchor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors je n'ai pas d'ancrage."
          }
        }
      }
    },
    "dialogue.lore.kael.3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "He waited twenty years."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il a attendu vingt ans."
          }
        }
      }
    },
    "dialogue.lore.lyra.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Guardian can become that?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un Gardien peut devenir ça ?"
          }
        }
      }
    },
    "dialogue.lyra.quest.active1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Did you find the 5 Shards? No? Try Mara's shop, she should have some in stock."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu as trouvé les 5 Éclats ? Non ? Essaye chez Mara, elle devrait en avoir en stock."
          }
        }
      }
    },
    "dialogue.lyra.quest.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Count on me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Compte sur moi."
          }
        }
      }
    },
    "dialogue.lyra.quest.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What is an Aether Shard?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Qu'est-ce qu'un Éclat d'Aether ?"
          }
        }
      }
    },
    "dialogue.lyra.quest.complete1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have them! Let me see… Extraordinary. The energy emanating from them is fascinating."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu les as ! Laisse-moi voir… Extraordinaire. L'énergie qui en émane est fascinante."
          }
        }
      }
    },
    "dialogue.lyra.quest.complete2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Here, take this as thanks. You've earned it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiens, prends ceci pour te remercier. Tu as bien mérité."
          }
        }
      }
    },
    "dialogue.lyra.quest.done1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My analysis is progressing thanks to your shards. You've done me a great service, Kael."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mes analyses avancent grâce à tes éclats. Tu m'as rendu un immense service, Kael."
          }
        }
      }
    },
    "dialogue.lyra.quest.give1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael, I need your help. My research on the Black Aether is progressing, but I'm missing components."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael, j'ai besoin de ton aide. Mes recherches sur l'Aether noir avancent, mais il me manque des composants."
          }
        }
      }
    },
    "dialogue.lyra.quest.give2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you could bring me 5 Aether Shards, I could understand what's corrupting these lands."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si tu pouvais me ramener 5 Éclats d'Aether, je pourrais comprendre ce qui corrompt ces terres."
          }
        }
      }
    },
    "dialogue.lyra.quest.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "… These shards resonate with the mark on my arm. It's strange."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "… Ces éclats résonnent avec la marque sur mon bras. C'est étrange."
          }
        }
      }
    },
    "dialogue.lyra.quest.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accept Lyra's quest?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accepter la quête de Lyra ?"
          }
        }
      }
    },
    "dialogue.lyra.quest.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thank you, Kael. Mara sells them at her shop, or you might find some in the forest."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merci, Kael. Mara en vend à sa boutique, ou tu en trouveras peut-être dans la forêt."
          }
        }
      }
    },
    "dialogue.lyra.quest.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Crystals that concentrate Aether energy. Mara has some in her shop. Bring me 5, it's important."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des cristaux qui concentrent l'énergie de l'Aether. Mara en a dans sa boutique. Ramène-m'en 5, c'est important."
          }
        }
      }
    },
    "dialogue.lyra.village.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Did Dorin say something?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dorin t'a dit quelque chose ?"
          }
        }
      }
    },
    "dialogue.lyra.village.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can handle it. Stop worrying."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je gère. Arrête de t'inquiéter."
          }
        }
      }
    },
    "dialogue.lyra.village.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What do you mean?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Que veux-tu dire ?"
          }
        }
      }
    },
    "dialogue.lyra.village.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "He thinks you're a threat. I disagree... but I understand his fear."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il pense que tu es une menace. Je ne suis pas d'accord... mais je comprends sa peur."
          }
        }
      }
    },
    "dialogue.lyra.village.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I worry because I saw that black Aether come out of you. Nobody else can do that."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je m'inquiète parce que j'ai vu cet Aether noir sortir de toi. Personne d'autre ne peut faire ça."
          }
        }
      }
    },
    "dialogue.lyra.village1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael, please be careful. The village isn't as calm as it seems."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael, je t'en supplie, sois prudent. Le village n'est pas aussi calme qu'il y paraît."
          }
        }
      }
    },
    "dialogue.lyra.village2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explore the village. Talk to people. Maybe someone knows something about the forest."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Explore le village. Parle aux habitants. Peut-être que quelqu'un sait quelque chose sur la forêt."
          }
        }
      }
    },
    "dialogue.mara.first.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sure, I'll bring it to him."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bien sûr, je le lui apporte."
          }
        }
      }
    },
    "dialogue.mara.first.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "And if I don't?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Et si je passe mon chemin ?"
          }
        }
      }
    },
    "dialogue.mara.first.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Is it urgent for him?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C'est important pour lui ?"
          }
        }
      }
    },
    "dialogue.mara.first.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thank you! There's a 15 gold reward in it for you. And in return, I've got potions for you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merci ! Il y a 15 pièces d'or de récompense à la clé. Et en échange, j'ai des potions pour toi."
          }
        }
      }
    },
    "dialogue.mara.first.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then Garen limps for another week. But that's your call. My herbs are still available for you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors Garen boitera encore une semaine. Mais c'est ton choix. Mes herbes sont quand même disponibles pour toi."
          }
        }
      }
    },
    "dialogue.mara.first1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Oh! A new face! I'm Mara. Herbs, potions, remedies: I sell everything that heals."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oh ! Un nouveau visage ! Je suis Mara. Herbes, potions, remèdes : je vends tout ce qui guérit."
          }
        }
      }
    },
    "dialogue.mara.first2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Oh, and I have a favour to ask. Garen, the north gate guard, is waiting for medicinal herbs for his leg. Could you bring them to him?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ah, et j'ai un service à te demander. Garen, le garde de la porte nord, attend des herbes médicinales pour sa jambe. Tu pourrais les lui apporter ?"
          }
        }
      }
    },
    "dialogue.mara.first3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In the meantime, take a look at my shop!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En attendant, jette un œil à ma boutique !"
          }
        }
      }
    },
    "dialogue.mara.quest1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Haven't delivered to Garen yet? Go on, he's waiting!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu n'as pas encore livré à Garen ? Allez, il t'attend !"
          }
        }
      }
    },
    "dialogue.mara.quest2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In the meantime, my potions are here if you need them."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Entre-temps, mes potions sont là si t'en as besoin."
          }
        }
      }
    },
    "dialogue.mara.shop1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're back! What do you need today?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "De retour ! Qu'est-ce qu'il te faut aujourd'hui ?"
          }
        }
      }
    },
    "dialogue.mark.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This scar..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette cicatrice..."
          }
        }
      }
    },
    "dialogue.mark.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I don't know where it came from. But it's been there a long time. I can feel it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne sais pas d'où elle vient. Mais elle est là depuis longtemps. Je le sens."
          }
        }
      }
    },
    "dialogue.mark.kael3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "As if it were the only thing that truly belongs to me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comme si c'était la seule chose qui m'appartient vraiment."
          }
        }
      }
    },
    "dialogue.mines.boss.post1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ash. It was made of nothing but ash and Aether."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "De la cendre. Il n'était fait que de cendre et d'Aether."
          }
        }
      }
    },
    "dialogue.mines.boss.post2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The mines are silent. For good, this time."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les mines sont silencieuses. Cette fois pour de bon."
          }
        }
      }
    },
    "dialogue.mines.boss.pre1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The ground shakes. Dust falls from the beams."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le sol tremble. La poussière tombe des étais."
          }
        }
      }
    },
    "dialogue.mines.boss.pre2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something is climbing up from the depths. Something heavy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelque chose remonte des profondeurs. Quelque chose de lourd."
          }
        }
      }
    },
    "dialogue.mines.combat1.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "They were miners. Men, before the ash took them."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C'était des mineurs. Des hommes, avant que la cendre les prenne."
          }
        }
      }
    },
    "dialogue.mines.combat1.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The tunnel goes deeper. And something is breathing down there."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La galerie descend encore. Et quelque chose respire, en bas."
          }
        }
      }
    },
    "dialogue.mines.enter.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Cendreval mines. Dorin said no one ever comes back from here."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les mines de Cendreval. Dorin disait que plus personne n'en revenait."
          }
        }
      }
    },
    "dialogue.mines.enter.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Promise. Let's see what silences the picks."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Promis. Voyons ce qui fait taire les pioches."
          }
        }
      }
    },
    "dialogue.mines.enter.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'll watch the entrance. If it goes wrong, you shout. Promise?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je garde l'entrée. Si ça tourne mal, tu cries. Promis ?"
          }
        }
      }
    },
    "dialogue.mines.gold.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An untouched gold vein. The miners won't be coming back for it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une veine d'or intacte. Les mineurs ne reviendront pas la chercher."
          }
        }
      }
    },
    "dialogue.mines.inscription.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Crew 7. The vein sings at night. We keep digging.\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "«Équipe 7. La veine chante la nuit. On continue de creuser.»"
          }
        }
      }
    },
    "dialogue.mines.inscription.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Crew 7. Last entry. The singing stopped.\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "«Équipe 7. Dernier relevé. Le chant s'est arrêté.»"
          }
        }
      }
    },
    "dialogue.mines.inscription.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "They dug all the way to the Source. Nobody warned them."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ils ont creusé jusqu'à la Source. Personne ne les avait prévenus."
          }
        }
      }
    },
    "dialogue.mines.plaqueName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Carved plaque"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Plaque gravée"
          }
        }
      }
    },
    "dialogue.oldwoman.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My son left for the mines last month. He never came back."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mon fils est parti aux mines le mois dernier. Il n'est pas revenu."
          }
        }
      }
    },
    "dialogue.oldwoman.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're heading north? Bring him back. Please."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous allez vers le nord ? Ramenez-le. S'il vous plaît."
          }
        }
      }
    },
    "dialogue.pact.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dorin told you about the disappearances."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dorin t'a parlé des disparitions."
          }
        }
      }
    },
    "dialogue.pact.10": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I didn't ask you to."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne te l'ai pas demandé."
          }
        }
      }
    },
    "dialogue.pact.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oui."
          }
        }
      }
    },
    "dialogue.pact.3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My father disappeared in the mines two years ago. Before anyone spoke of corruption."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mon père a disparu dans les mines il y a deux ans. Avant que quiconque parle de corruption."
          }
        }
      }
    },
    "dialogue.pact.4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "And you think it's connected."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Et tu penses que c'est lié."
          }
        }
      }
    },
    "dialogue.pact.5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I think I'm going to find out. With or without you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je pense que je vais aller voir. Avec ou sans toi."
          }
        }
      }
    },
    "dialogue.pact.6": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This isn't my war."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce n'est pas ma guerre."
          }
        }
      }
    },
    "dialogue.pact.7": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No. It's mine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non. C'est la mienne."
          }
        }
      }
    },
    "dialogue.pact.8": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "But you need to go north to find what you lost. And I need someone who can touch corrupted Aether. We can be of use to each other."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mais toi tu as besoin d'aller vers le nord pour retrouver ce que tu as perdu. Et moi j'ai besoin de quelqu'un qui peut toucher l'Aether corrompu. On peut se rendre service mutuellement."
          }
        }
      }
    },
    "dialogue.pact.9": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I won't protect you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne te protègerai pas."
          }
        }
      }
    },
    "dialogue.ruins.real.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These crystals... they've been drained. The energy was torn out of them. That's why the forest is dying. Its source was stolen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces cristaux... ils ont été vidés. L'énergie en a été extraite de force. C'est pour ça que la forêt est mourante. On lui a volé sa source."
          }
        }
      }
    },
    "dialogue.sage.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tell me about the black Aether."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parle-moi de l'Aether noir."
          }
        }
      }
    },
    "dialogue.sage.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I just want to rest."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je veux juste me reposer."
          }
        }
      }
    },
    "dialogue.sage.first1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome, traveller. This inn has sheltered the weary since before you were born."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bienvenue, voyageur. Cette auberge accueille les épuisés depuis avant ta naissance."
          }
        }
      }
    },
    "dialogue.sage.first2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You look like you've been through something heavy. Rest does miracles that swords cannot."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu as l'air d'avoir traversé quelque chose de lourd. Le repos fait des miracles que les épées ne font pas."
          }
        }
      }
    },
    "dialogue.sage.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Do you know anything about the forest?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu sais quelque chose sur la forêt ?"
          }
        }
      }
    },
    "dialogue.sage.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Black Aether predates this village. A thousand-year-old legend. But lately... it's as if it's awakening. Inside someone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'Aether noir existait avant ce village. Des légendes vieilles de mille ans. Mais ces derniers temps... c'est comme s'il se réveillait. En quelqu'un."
          }
        }
      }
    },
    "dialogue.sage.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Of course. 10 gold for the night. You'll leave in top shape, guaranteed."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bien sûr. 10 pièces d'or pour la nuit. Tu repars en pleine forme, garanti."
          }
        }
      }
    },
    "dialogue.sage.rest1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Did you sleep well? The inn has a long memory: it keeps people alive longer than their swords do."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu t'es bien reposé ? L'auberge a bonne mémoire : elle garde les gens en vie plus longtemps que leurs épées."
          }
        }
      }
    },
    "dialogue.sage.rest2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Be careful in the forest. What sleeps in there is not ordinary."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prudence dans la forêt. Ce qui dort là-dedans n'est pas ordinaire."
          }
        }
      }
    },
    "dialogue.save.line1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Progress saved."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Progression sauvegardée."
          }
        }
      }
    },
    "dialogue.save.speakerName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Crystal"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cristal"
          }
        }
      }
    },
    "dialogue.shades.pre1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These echoes do not want rest. The Void has turned them inside out."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces échos-là ne veulent pas du repos. Le Vide les a retournés."
          }
        }
      }
    },
    "dialogue.shades.pre2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then we free them our way."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors on les libère à notre manière."
          }
        }
      }
    },
    "dialogue.shrine.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn away from the sanctuary. Without a word."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tourner le dos au sanctuaire. Sans un mot."
          }
        }
      }
    },
    "dialogue.shrine.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My memory is a price I'm willing to pay."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ma mémoire est un prix que je suis prêt à payer."
          }
        }
      }
    },
    "dialogue.shrine.choice3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tell me who I am. I'll decide after."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dis-moi qui je suis. Je déciderai ensuite."
          }
        }
      }
    },
    "dialogue.shrine.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let's go back. For now."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "On rentre. Pour l'instant."
          }
        }
      }
    },
    "dialogue.shrine.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael, don't listen! That voice... it's the same energy as your mark. It's a trap!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael, ne l'écoute pas ! Cette voix... c'est la même énergie que ta marque. C'est un piège !"
          }
        }
      }
    },
    "dialogue.shrine.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... your eyes. For a moment, they were completely black. You're scaring me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... tes yeux. Pendant un instant, ils étaient complètement noirs. Tu me fais peur."
          }
        }
      }
    },
    "dialogue.shrine.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael's choice"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le choix de Kael"
          }
        }
      }
    },
    "dialogue.shrine.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You'll come back. They all come back."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu reviendras. Ils reviennent tous."
          }
        }
      }
    },
    "dialogue.shrine.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Admirable. But the void doesn't ask permission. It takes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Admirable. Mais le vide ne demande pas de permission. Il prend."
          }
        }
      }
    },
    "dialogue.shrine.response3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You were someone who didn't ask questions. Someone who took."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu étais quelqu'un qui ne posait pas de questions. Quelqu'un qui prenait."
          }
        }
      }
    },
    "dialogue.shrine.voice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You came back. I knew you would. The void recognizes its own."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu es revenu. Je savais que tu reviendrais. Le vide reconnaît les siens."
          }
        }
      }
    },
    "dialogue.shrine.voice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "They will hold you back. The girl with her staff. The chief with his fear. They call it caution."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ils te retiendront. La fille avec son bâton. Le chef avec sa peur. Ils appellent ça de la prudence."
          }
        }
      }
    },
    "dialogue.shrine.voice3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can give you back what they took. Your memory. Your name. Everything you were before the ditch."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Moi, je peux te rendre ce qu'ils t'ont pris. Ta mémoire. Ton nom. Tout ce que tu étais avant le fossé."
          }
        }
      }
    },
    "dialogue.shrine.voiceName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voix"
          }
        }
      }
    },
    "dialogue.spirit.done1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Three echoes laid to rest. The Threshold grows lighter — I can feel it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trois échos rendus au repos. Le Seuil s'allège — je le sens."
          }
        }
      }
    },
    "dialogue.spirit.done2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let it get used to it. We're only getting started."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Qu'il s'habitue. On ne fait que commencer."
          }
        }
      }
    },
    "dialogue.spirit.guard1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I failed. The shrine's Guardian broke me, and the gate stood unwatched."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'ai failli. Le Gardien du sanctuaire m'a brisé, et la porte est restée sans veille."
          }
        }
      }
    },
    "dialogue.spirit.guard2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Beaten… Then at last I can lower my spear."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaincu… Alors je peux enfin baisser ma lance."
          }
        }
      }
    },
    "dialogue.spirit.guardKael": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Guardian lies cracked and beaten. Your watch is over, soldier."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Gardien est fêlé, vaincu. Ta veille est terminée, soldat."
          }
        }
      }
    },
    "dialogue.spirit.guardName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Guard's Spirit"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Esprit du garde"
          }
        }
      }
    },
    "dialogue.spirit.miner1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The gallery… did it hold? Did the others make it out?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La galerie… elle a tenu, dis ? Les autres sont sortis ?"
          }
        }
      }
    },
    "dialogue.spirit.miner2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then I can set down my lantern… thank you, traveler."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alors je peux poser la lanterne… merci, voyageur."
          }
        }
      }
    },
    "dialogue.spirit.minerKael": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Cendreval mines are silent now. The golem fell. They rest in peace."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les mines de Cendreval sont silencieuses. Le golem est tombé. Ils reposent en paix."
          }
        }
      }
    },
    "dialogue.spirit.minerName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Miner's Spirit"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Esprit du mineur"
          }
        }
      }
    },
    "dialogue.spirit.mother1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My little one… he played by the fountain. I never got to tuck him in."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mon petit… il jouait près de la fontaine. Je n'ai pas eu le temps de le border."
          }
        }
      }
    },
    "dialogue.spirit.mother2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "He laughs… that is all I needed to hear."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il rit… c'est tout ce que je voulais entendre."
          }
        }
      }
    },
    "dialogue.spirit.motherKael": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The child of Solis still laughs by the fountain. He wears your medallion."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'enfant de Solis rit encore près de la fontaine. Il porte votre médaillon."
          }
        }
      }
    },
    "dialogue.spirit.motherName": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mother's Spirit"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Esprit de la mère"
          }
        }
      }
    },
    "dialogue.stele.1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\\u201cHere knelt Eran, first of the Watchers, who believed the Void could be bargained with.\\u201d"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Ici s'agenouilla Eran, premier des Veilleurs, qui crut pouvoir marchander avec le Vide. »"
          }
        }
      }
    },
    "dialogue.stele.2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\\u201cThe Void does not take. It TRADES: a memory for a power, a name for an eternity.\\u201d"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Le Vide ne prend pas. Il ÉCHANGE : un souvenir contre un pouvoir, un nom contre une éternité. »"
          }
        }
      }
    },
    "dialogue.stele.3": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\\u201cEran gave his name. The Threshold keeps it still. It is all that remains to be returned.\\u201d"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Eran donna son nom. Le Seuil le garde encore. C'est tout ce qu'il reste à rendre. »"
          }
        }
      }
    },
    "dialogue.stele.done": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Three steles. Three debts. Eran… what did you truly leave here?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trois stèles. Trois dettes. Eran… qu'as-tu vraiment laissé ici ?"
          }
        }
      }
    },
    "dialogue.stele.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Void Stele"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Stèle du Vide"
          }
        }
      }
    },
    "dialogue.villager.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calm down. I can help."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Calme-toi. Je peux aider."
          }
        }
      }
    },
    "dialogue.villager.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm sorry you're going through this."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je suis désolé pour toi."
          }
        }
      }
    },
    "dialogue.villager.line1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave me alone! Those creatures from the forest come into the village at night... I haven't slept in three days."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Laisse-moi tranquille ! Ces créatures de la forêt arrivent jusque dans le village la nuit... J'ai pas dormi depuis trois jours."
          }
        }
      }
    },
    "dialogue.villager.line2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay away from the forest edge if you value your life."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reste à l'écart de la lisière si tu tiens à ta vie."
          }
        }
      }
    },
    "dialogue.villager.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Villager"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Villageois"
          }
        }
      }
    },
    "dialogue.villager.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What did you see?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Qu'est-ce que tu as vu ?"
          }
        }
      }
    },
    "dialogue.villager.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You? Those things resist normal blades. I saw one absorb an entire arrow without flinching."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toi ? Ces choses résistent aux lames normales. J'ai vu l'une d'elles absorber une flèche entière sans broncher."
          }
        }
      }
    },
    "dialogue.villager.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sorry doesn't help. But... thank you. At least you're not pretending everything's fine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La désolation aide pas. Mais... merci. Au moins toi, tu prétends pas que tout va bien."
          }
        }
      }
    },
    "dialogue.vision.eran.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You must seal your memory, Kael."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu dois sceller ta mémoire, Kael."
          }
        }
      }
    },
    "dialogue.vision.eran.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's the only way to protect you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C'est le seul moyen de te protéger."
          }
        }
      }
    },
    "dialogue.wake.choice1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "..."
          }
        }
      }
    },
    "dialogue.wake.choice2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If I knew that, I wouldn't be lying here."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si je le savais, je ne serais pas allongé là."
          }
        }
      }
    },
    "dialogue.wake.choice3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. It's the only word that comes back when I close my eyes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael. C'est le seul mot qui revient quand je ferme les yeux."
          }
        }
      }
    },
    "dialogue.wake.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Where am I? What is this place?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Où suis-je ? Qu'est-ce que c'est, cet endroit ?"
          }
        }
      }
    },
    "dialogue.wake.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I don't remember anything. Just... cold. And a voice."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne me souviens de rien. Juste... du froid. Et d'une voix."
          }
        }
      }
    },
    "dialogue.wake.lyra1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hey. Can you hear me? You were out cold for three days."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hé. Tu m'entends ? Tu es resté inconscient trois jours."
          }
        }
      }
    },
    "dialogue.wake.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your left hand... it was glowing while you slept. Purple. Nobody dared touch you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta main gauche... elle brillait pendant ton sommeil. Violette. Personne n'a osé te toucher."
          }
        }
      }
    },
    "dialogue.wake.lyra3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Solis. A village on the edge of the corruption. And I'm Lyra, the only one here who didn't want to leave you dying in a ditch."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Solis. Un village au bord de la corruption. Et moi c'est Lyra, la seule personne ici qui a pas voulu te laisser mourir dans le fossé."
          }
        }
      }
    },
    "dialogue.wake.lyra4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The whole village is talking about you. About your hand. People have vanished to the north, and you show up with a mark nobody recognizes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout le village parle de toi. De ta main. Des gens ont disparu au nord, et toi tu arrives avec une marque que personne ne reconnaît."
          }
        }
      }
    },
    "dialogue.wake.lyra5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A voice? We'll talk about that later. For now, Dorin wants to see you. The village chief. And he's far less patient than me."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une voix ? On en reparlera. Pour l'instant, Dorin veut te voir. Le chef du village. Et il est beaucoup moins patient que moi."
          }
        }
      }
    },
    "dialogue.wake.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reply as Kael"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Répondre en Kael"
          }
        }
      }
    },
    "dialogue.wake.real.kael1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael."
          }
        }
      }
    },
    "dialogue.wake.real.kael2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I think."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je crois."
          }
        }
      }
    },
    "dialogue.wake.real.kael3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Were they right to be afraid?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ils ont eu raison d'avoir peur ?"
          }
        }
      }
    },
    "dialogue.wake.real.lyra1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're awake. Good. You caused me enough trouble unconscious."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu es réveillé. Bien. Tu m'as causé assez de problèmes inconscient."
          }
        }
      }
    },
    "dialogue.wake.real.lyra2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Do you at least know your name?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu sais comment tu t'appelles au moins ?"
          }
        }
      }
    },
    "dialogue.wake.real.lyra3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The village found you at the forest's edge. Unconscious. The mark on your hand was glowing. People were afraid. So was I, if you want to know."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le village t'a trouvé à la lisière de la forêt. Inconscient. La marque sur ta main brillait. Les gens avaient peur. Moi aussi, si tu veux savoir."
          }
        }
      }
    },
    "dialogue.wake.real.lyra4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I don't know yet. Eat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne sais pas encore. Mange."
          }
        }
      }
    },
    "dialogue.wake.response1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "...Fine. We'll start with silence then. At least you're alive."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "...D'accord. On commencera par le silence alors. Au moins tu es vivant."
          }
        }
      }
    },
    "dialogue.wake.response2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Charming. Amnesia with attitude. That's a first around here."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Charmant. L'amnésie avec de la répartie, c'est une première ici."
          }
        }
      }
    },
    "dialogue.wake.response3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... That name means nothing to me. But your mark says a lot."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kael... Ce nom ne me dit rien. Mais ta marque, elle, dit beaucoup."
          }
        }
      }
    },
