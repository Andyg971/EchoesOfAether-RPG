          }
        }
      }
    },
    "quest.sageHerb.acceptResponse": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Look for a pale glow between the roots, west of the trail. Thank you, Kael."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cherche une lueur pâle entre les racines, à l'ouest du sentier. Merci, Kael."
