    "lore.threshold.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Crossing the Threshold without an anchor is to become what one fears most."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Franchir le Seuil sans ancrage, c'est devenir ce qu'on craint le plus."
          }
        }
      }
    },
    "lore.threshold.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
