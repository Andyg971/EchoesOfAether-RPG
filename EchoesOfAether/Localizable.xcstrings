    "lore.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Aether Journal"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Journal de l'Éther"
          }
        }
      }
    },
    "lore.void.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "She was right. About everything. And Kael can no longer hear her."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Elle avait raison. Sur tout. Et Kael ne peut plus l'entendre."
          }
        }
      }
    },
    "lore.void.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fragment of the Void"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fragment du Vide"
          }
        }
      }
    },
    "lore.voidheart.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Beneath the Threshold beats the source of every echo. Neither god nor monster: a memory turned to hunger, collecting lives the way others collect stones. Whoever reaches it must choose what is to be done with the memory of the dead."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sous le Seuil bat la source de tous les échos. Ce n'est ni un dieu ni un monstre : une mémoire devenue faim, qui collectionne les vies comme d'autres collectionnent les pierres. Quiconque l'atteint doit choisir ce que l'on fait du souvenir des morts."
          }
        }
      }
    },
    "lore.voidheart.title": {
      "localizations": {
