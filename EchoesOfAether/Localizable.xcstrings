    "quest.garenScout.accept": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'll keep an eye out."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je garderai l'œil ouvert."
          }
        }
      }
    },
    "quest.garenScout.acceptResponse": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "His badge. Bring me his badge at least, so I know."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Son insigne. Rapporte-moi au moins son insigne, que je sache."
          }
        }
      }
    },
    "quest.garenScout.active": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tomm wore the guard's badge. Three days now."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tomm portait l'insigne de la garde. Trois jours, déjà."
          }
        }
      }
    },
    "quest.garenScout.decline": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can't promise anything."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne peux rien promettre."
          }
        }
      }
    },
    "quest.garenScout.declineResponse": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "…I understand. The forest takes more than it gives back."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "…Je comprends. La forêt prend plus qu'elle ne rend."
          }
        }
      }
    },
    "quest.garenScout.done1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "His badge… So that's it. Thank you, Kael. At least now I know."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Son insigne… C'est donc ça. Merci, Kael. Au moins, je sais."
          }
        }
      }
    },
    "quest.garenScout.done2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "He used to say the forest sang, once. Nobody says that anymore."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il aimait dire que la forêt chantait, avant. Plus personne ne dit ça."
          }
        }
      }
    },
    "quest.garenScout.found": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A guard's badge, half buried. Dried blood on the metal. …I'm sorry, Tomm."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un insigne de la garde, à moitié enfoui. Du sang séché sur le métal. …Désolé, Tomm."
          }
        }
      }
    },
    "quest.garenScout.hud": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find the missing scout (forest)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Retrouver l'éclaireur disparu (forêt)"
          }
        }
      }
    },
    "quest.garenScout.offer1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One of my scouts hasn't come back. Tomm. Went into the forest three days ago."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un de mes éclaireurs n'est pas rentré. Tomm. Parti vers la forêt il y a trois jours."
          }
        }
      }
    },
    "quest.garenScout.offer2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search for traces of the scout?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chercher des traces de l'éclaireur ?"
          }
        }
      }
    },
    "quest.lyraShards.name": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Aether Shards (Lyra)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Éclats d'Aether (Lyra)"
          }
