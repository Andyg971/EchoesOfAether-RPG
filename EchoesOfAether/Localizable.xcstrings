    "shop.bram.runicBlade.name" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Lame Runique" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Runic Blade" } }
      }
    },
    "shop.bram.runicBlade.desc" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "+44 ATK / +70 Entaille" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "+44 ATK / +70 Slash" } }
      }
    },
    "shop.bram.chainMail.name" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Cotte de Mailles" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Chain Mail" } }
      }
    },
    "shop.bram.chainMail.desc" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "+50 HP max" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "+50 max HP" } }
      }
    },
    "shop.bram.reinforced.name" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Armure Renforcée" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Reinforced Armor" } }
      }
    },
    "shop.bram.reinforced.desc" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "+100 HP max" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "+100 max HP" } }
      }
    },
    "shop.mara.potion.name" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Potion de Soin" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Healing Potion" } }
      }
    },
    "shop.mara.potion.desc" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Restaure des PV (max 3)" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Restores HP (max 3)" } }
      }
    },
    "shop.mara.aetherShard.name" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Éclat d'Aether" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Aether Shard" } }
      }
    },
    "shop.mara.aetherShard.desc" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Recharge ATB en combat" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Charges ATB in combat" } }
      }
    },
    "shop.inn.rest.name" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Nuit à l'Auberge" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Inn Rest" } }
      }
    },
    "shop.inn.rest.desc" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Récupère tous tes PV" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Fully restores your HP" } }
      }
    },

    "dialogue.lyra.village1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Kael, je t'en supplie, sois prudent. Le village n'est pas aussi calme qu'il y paraît." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Kael, please be careful. The village isn't as calm as it seems." } }
      }
    },
    "dialogue.lyra.village.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Que veux-tu dire ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "What do you mean?" } }
      }
    },
    "dialogue.lyra.village.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Dorin t'a dit quelque chose ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Did Dorin say something?" } }
      }
    },
    "dialogue.lyra.village.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Il pense que tu es une menace. Je ne suis pas d'accord... mais je comprends sa peur." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "He thinks you're a threat. I disagree... but I understand his fear." } }
      }
    },
    "dialogue.lyra.village.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je gère. Arrête de t'inquiéter." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I can handle it. Stop worrying." } }
      }
    },
    "dialogue.lyra.village.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je m'inquiète parce que j'ai vu cet Aether noir sortir de toi. Personne d'autre ne peut faire ça." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I worry because I saw that black Aether come out of you. Nobody else can do that." } }
      }
    },
    "dialogue.lyra.village2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Explore le village. Parle aux habitants. Peut-être que quelqu'un sait quelque chose sur la forêt." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Explore the village. Talk to people. Maybe someone knows something about the forest." } }
      }
    },

    "dialogue.bram.bram1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Hé, toi ! T'as une tête de combattant. J'ai exactement ce qu'il te faut." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Hey, you! You've got a fighter's look. I've got just what you need." } }
      }
    },
    "dialogue.bram.bram2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ma forge tourne depuis trente ans. Chaque lame que j'ai faite a survécu à son propriétaire. Ça dit tout." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "My forge has been running thirty years. Every blade I made outlasted its owner. That says it all." } }
      }
    },
    "dialogue.bram.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Montre-moi ce que tu as." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Show me what you've got." } }
      }
    },
    "dialogue.bram.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je cherche une arme solide." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I need a solid weapon." } }
      }
    },
    "dialogue.bram.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Alors t'es au bon endroit. Du fer, du runique — tout ce qu'il faut pour survivre là-dehors. Regarde." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Then you're in the right place. Iron, runic — everything you need to survive out there. Take a look." } }
      }
    },
    "dialogue.bram.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je veux juste regarder." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Just browsing." } }
      }
    },
    "dialogue.bram.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Pas de problème. Reviens quand t'as des pièces d'or. La qualité a un prix." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No problem. Come back when you've got gold. Quality has a price." } }
      }
    },

    "dialogue.mara.first1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Oh ! Un nouveau visage ! Je suis Mara. Herbes, potions, remèdes — je vends tout ce qui guérit." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Oh! A new face! I'm Mara. Herbs, potions, remedies — I sell everything that heals." } }
      }
    },
    "dialogue.mara.first2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ah, et j'ai un service à te demander. Garen, le garde de la porte nord, attend des herbes médicinales pour sa jambe. Tu pourrais les lui apporter ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Oh, and I have a favour to ask. Garen, the north gate guard, is waiting for medicinal herbs for his leg. Could you bring them to him?" } }
      }
    },
    "dialogue.mara.first.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "C'est important pour lui ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Is it urgent for him?" } }
      }
    },
    "dialogue.mara.first.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Bien sûr, je le lui apporte." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Sure, I'll bring it to him." } }
      }
    },
    "dialogue.mara.first.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Merci ! Il y a 15 pièces d'or de récompense à la clé. Et en échange, j'ai des potions pour toi." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Thank you! There's a 15 gold reward in it for you. And in return, I've got potions for you." } }
      }
    },
    "dialogue.mara.first.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Et si je passe mon chemin ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "And if I don't?" } }
      }
    },
    "dialogue.mara.first.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Alors Garen boitera encore une semaine. Mais c'est ton choix. Mes herbes sont quand même disponibles pour toi." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Then Garen limps for another week. But that's your call. My herbs are still available for you." } }
      }
    },
    "dialogue.mara.first3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "En attendant, jette un œil à ma boutique !" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "In the meantime, take a look at my shop!" } }
      }
    },
    "dialogue.mara.quest1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu n'as pas encore livré à Garen ? Allez, il t'attend !" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Haven't delivered to Garen yet? Go on, he's waiting!" } }
      }
    },
    "dialogue.mara.quest2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Entre-temps, mes potions sont là si t'en as besoin." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "In the meantime, my potions are here if you need them." } }
      }
    },
    "dialogue.mara.shop1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "De retour ! Qu'est-ce qu'il te faut aujourd'hui ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You're back! What do you need today?" } }
      }
    },

    "dialogue.garen.first1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Halte. La porte nord est fermée sur ordre du chef du village." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Stop. The north gate is closed by order of the village elder." } }
      }
    },
    "dialogue.garen.first2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La forêt est infestée depuis deux semaines. Personne ne passe. Dans aucun sens." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The forest has been infested for two weeks. Nobody gets through. Either way." } }
      }
    },
    "dialogue.garen.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Il n'y a aucune exception ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No exceptions?" } }
      }
    },
    "dialogue.garen.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je suis un combattant, je peux gérer." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I'm a fighter, I can handle it." } }
      }
    },
    "dialogue.garen.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "J'en suis sûr. Mais les ordres sont les ordres. Pour partir par ici, parle à Dorin." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I'm sure you can. But orders are orders. If you want out this way, talk to Dorin." } }
      }
    },
    "dialogue.garen.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je comprends. Je repasserai." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Understood. I'll come back." } }
      }
    },
    "dialogue.garen.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Sage décision. Au fait — si tu croises Mara l'herboriste, elle a quelque chose pour moi." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Wise choice. By the way — if you run into Mara the herbalist, she has something for me." } }
      }
    },
    "dialogue.garen.delivery1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le colis de Mara ! Enfin. T'as fait ça vite." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Mara's package! Finally. You were quick." } }
      }
    },
    "dialogue.garen.delivery2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Prends ça, c'est mérité. Et dis-lui qu'elle peut envoyer un vrai messager la prochaine fois." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Take this, you earned it. And tell her to send a real messenger next time." } }
      }
    },
    "dialogue.garen.done1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tout est en ordre. Si tu veux partir vers le nord, parle à Dorin — c'est lui qui décide." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "All sorted. If you want to head north, talk to Dorin — he's the one who decides." } }
      }
    },

    "dialogue.sage.first1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Bienvenue, voyageur. Cette auberge accueille les épuisés depuis avant ta naissance." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Welcome, traveller. This inn has sheltered the weary since before you were born." } }
      }
    },
    "dialogue.sage.first2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu as l'air d'avoir traversé quelque chose de lourd. Le repos fait des miracles que les épées ne font pas." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You look like you've been through something heavy. Rest does miracles that swords cannot." } }
      }
    },
    "dialogue.sage.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu sais quelque chose sur la forêt ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Do you know anything about the forest?" } }
      }
    },
    "dialogue.sage.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Parle-moi de l'Aether noir." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Tell me about the black Aether." } }
      }
    },
    "dialogue.sage.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "L'Aether noir existait avant ce village. Des légendes vieilles de mille ans. Mais ces derniers temps... c'est comme s'il se réveillait. En quelqu'un." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Black Aether predates this village. A thousand-year-old legend. But lately... it's as if it's awakening. Inside someone." } }
      }
    },
    "dialogue.sage.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je veux juste me reposer." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I just want to rest." } }
      }
    },
    "dialogue.sage.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Bien sûr. 10 pièces d'or pour la nuit. Tu repars en pleine forme — garanti." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Of course. 10 gold for the night. You'll leave in top shape — guaranteed." } }
      }
    },
    "dialogue.sage.rest1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu t'es bien reposé ? L'auberge a bonne mémoire — elle garde les gens en vie plus longtemps que leurs épées." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Did you sleep well? The inn has a long memory — it keeps people alive longer than their swords do." } }
      }
    },
    "dialogue.sage.rest2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Prudence dans la forêt. Ce qui dort là-dedans n'est pas ordinaire." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Be careful in the forest. What sleeps in there is not ordinary." } }
      }
    },

    "dialogue.child.name" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Enfant" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Child" } }
      }
    },
    "dialogue.child.line1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Hé ! T'as pas l'air d'être du village. T'es un aventurier ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Hey! You don't look like you're from the village. Are you an adventurer?" } }
      }
    },
    "dialogue.child.line2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Mon père dit de pas s'approcher de la forêt. Mais j'ai vu une lumière noire là-dedans hier soir !" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "My dad says not to go near the forest. But I saw a black light in there last night!" } }
      }
    },
    "dialogue.child.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu as peur ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Are you scared?" } }
      }
    },
    "dialogue.child.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Un peu de curiosité, c'est bien." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A little curiosity is good." } }
      }
    },
    "dialogue.child.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ouais ! Je veux devenir comme toi — un vrai guerrier avec des pouvoirs !" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Yeah! I want to be like you — a real warrior with powers!" } }
      }
    },
    "dialogue.child.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu dois rester à l'abri." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You need to stay safe." } }
      }
    },
    "dialogue.child.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je sais... mais c'est tellement ennuyeux ici. C'est vrai que t'as des pouvoirs magiques ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I know... but it's so boring here. Is it true you have magic powers?" } }
      }
    },

    "dialogue.villager.name" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Villageois" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Villager" } }
      }
    },
    "dialogue.villager.line1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Laisse-moi tranquille ! Ces créatures de la forêt arrivent jusque dans le village la nuit... J'ai pas dormi depuis trois jours." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Leave me alone! Those creatures from the forest come into the village at night... I haven't slept in three days." } }
      }
    },
    "dialogue.villager.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Qu'est-ce que tu as vu ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "What did you see?" } }
      }
    },
    "dialogue.villager.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Calme-toi. Je peux aider." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Calm down. I can help." } }
      }
    },
    "dialogue.villager.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Toi ? Ces choses résistent aux lames normales. J'ai vu l'une d'elles absorber une flèche entière sans broncher." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You? Those things resist normal blades. I saw one absorb an entire arrow without flinching." } }
      }
    },
    "dialogue.villager.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je suis désolé pour toi." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I'm sorry you're going through this." } }
      }
    },
    "dialogue.villager.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La désolation aide pas. Mais... merci. Au moins toi, tu prétends pas que tout va bien." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Sorry doesn't help. But... thank you. At least you're not pretending everything's fine." } }
      }
    },
    "dialogue.villager.line2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Reste à l'écart de la lisière si tu tiens à ta vie." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Stay away from the forest edge if you value your life." } }
      }
    }
  },
  "version" : "1.0"
}
