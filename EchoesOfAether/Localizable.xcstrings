    "lore.archivist.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Source is a mirror. It amplifies. It does not corrupt. It shows."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La Source est un miroir. Elle amplifie. Elle ne corrompt pas. Elle montre."
          }
        }
      }
    },
    "lore.archivist.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivist's Notes"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Notes de l'Archiviste"
          }
        }
      }
    },
    "lore.cendreval.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The vein sang at night. They dug deeper, until they touched the Source. The ash did the rest."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La veine chantait la nuit. Ils ont creusé plus profond, jusqu'à toucher la Source. La cendre a fait le reste."
          }
        }
      }
    },
    "lore.cendreval.title": {
