    "combat.status.enemyHit %@ %lld %lld" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "%@ frappe Kael ! PV %lld/%lld" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "%@ hits Kael! HP %lld/%lld" } }
      }
    },
    "combat.status.attack %@" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Kael attaque ! %@ vacille." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Kael attacks! %@ staggers." } }
      }
    },
    "combat.status.blackSlash %lld" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Entaille noire ! Résonance %lld/3." } },
