      }
    },
    "endscreen.betrayal" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La trahison de Kael est amorcée." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Kael's betrayal has begun." } }
      }
    },

    "dialogue.wake.lyra1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Hé. Tu m'entends ? Tu es resté inconscient trois jours." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Hey. Can you hear me? You were out cold for three days." } }
      }
    },
    "dialogue.wake.lyra2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ta main gauche... elle brillait pendant ton sommeil. Violette. Personne n'a osé te toucher." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your left hand... it was glowing while you slept. Purple. Nobody dared touch you." } }
      }
    },
    "dialogue.wake.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Répondre en Kael" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Reply as Kael" } }
      }
    },
    "dialogue.wake.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "..." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "..." } }
      }
    },
    "dialogue.wake.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "...D'accord. On commencera par le silence alors. Au moins tu es vivant." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "...Fine. We'll start with silence then. At least you're alive." } }
      }
    },
    "dialogue.wake.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Si je le savais, je ne serais pas allongé là." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "If I knew that, I wouldn't be lying here." } }
      }
    },
    "dialogue.wake.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Charmant. L'amnésie avec de la répartie, c'est une première ici." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Charming. Amnesia with attitude — that's a first around here." } }
      }
    },
    "dialogue.wake.choice3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Kael. C'est le seul mot qui revient quand je ferme les yeux." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Kael. It's the only word that comes back when I close my eyes." } }
      }
    },
    "dialogue.wake.response3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Kael... Ce nom ne me dit rien. Mais ta marque, elle, dit beaucoup." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Kael... That name means nothing to me. But your mark says a lot." } }
      }
    },
    "dialogue.wake.kael1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Où suis-je ? Qu'est-ce que c'est, cet endroit ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Where am I? What is this place?" } }
      }
    },
    "dialogue.wake.lyra3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Solis. Un village au bord de la corruption. Et moi c'est Lyra — la seule personne ici qui a pas voulu te laisser mourir dans le fossé." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Solis. A village on the edge of the corruption. And I'm Lyra — the only one here who didn't want to leave you dying in a ditch." } }
      }
    },
    "dialogue.wake.lyra4" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tout le village parle de toi. De ta main. Des gens ont disparu au nord, et toi tu arrives avec une marque que personne ne reconnaît." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The whole village is talking about you. About your hand. People have vanished to the north, and you show up with a mark nobody recognizes." } }
      }
    },
    "dialogue.wake.kael2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je ne me souviens de rien. Juste... du froid. Et d'une voix." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I don't remember anything. Just... cold. And a voice." } }
      }
    },
    "dialogue.wake.lyra5" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Une voix ? On en reparlera. Pour l'instant, Dorin veut te voir. Le chef du village. Et il est beaucoup moins patient que moi." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A voice? We'll talk about that later. For now, Dorin wants to see you. The village chief. And he's far less patient than me." } }
      }
    },

    "dialogue.dorin.dorin1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Alors c'est toi. Celui que Lyra a ramassé sur le chemin. Avec la marque qui inquiète mes gardes." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "So you're the one. The one Lyra picked up on the road. With the mark that worries my guards." } }
      }
    },
    "dialogue.dorin.lyra1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Dorin, il ne sait même pas d'où il vient. Laisse-lui une chance." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Dorin, he doesn't even know where he's from. Give him a chance." } }
      }
    },
    "dialogue.dorin.dorin2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Trois éclaireurs. Disparus. La forêt pue la corruption. Et toi, tu débarques avec une main qui brille comme les créatures qui les ont pris. Alors je vais être direct." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Three scouts. Gone. The forest reeks of corruption. And you show up with a hand that glows like the creatures that took them. So I'll be direct." } }
      }
    },
    "dialogue.dorin.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Répondre à Dorin" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Reply to Dorin" } }
      }
    },
    "dialogue.dorin.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Regarder la marque en silence." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Stare at the mark in silence." } }
      }
    },
    "dialogue.dorin.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Même ton silence a quelque chose de menaçant. Mais les monstres, eux, ne se taisent pas." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Even your silence feels threatening. But the monsters out there don't stay quiet." } }
      }
    },
    "dialogue.dorin.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Vos morts ne me regardent pas. Je cherche mes propres réponses." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your dead aren't my problem. I'm looking for my own answers." } }
      }
    },
    "dialogue.dorin.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tes réponses sont au nord, Kael. Que tu le veuilles ou non, vos chemins mènent au même endroit." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your answers are to the north, Kael. Whether you like it or not, your paths lead to the same place." } }
      }
    },
    "dialogue.dorin.choice3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Si cette marque peut détruire ce qui les a pris... alors montrez-moi le chemin." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "If this mark can destroy what took them... then show me the way." } }
      }
    },
    "dialogue.dorin.response3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Du courage ou de l'inconscience. Dans les deux cas, ça m'arrange." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Courage or recklessness. Either way, it suits me." } }
      }
    },
    "dialogue.dorin.dorin3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La lisière est au nord. Si tu reviens vivant, on reparlera de confiance. Si tu ne reviens pas... eh bien, problème réglé." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The forest edge is to the north. Come back alive and we'll talk about trust. Don't come back... well, problem solved." } }
      }
    },
    "dialogue.dorin.lyra2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je viens avec toi. Pas pour te protéger — pour m'assurer que ta marque ne finisse pas par te consumer." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I'm coming with you. Not to protect you — to make sure your mark doesn't end up consuming you." } }
      }
    },

    "dialogue.aether.lyra1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Kael... Qu'est-ce que c'était ? Quand tu as frappé, l'air est devenu noir. J'ai senti le froid jusque dans mes os." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Kael... What was that? When you struck, the air turned black. I felt the cold down to my bones." } }
      }
    },
    "dialogue.aether.kael1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ce qui marchait. La créature est morte." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Whatever worked. The creature is dead." } }
      }
    },
    "dialogue.aether.lyra2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Morte, oui. Mais ta main tremble encore. Et tes veines... regarde. Elles sont noires, Kael." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Dead, yes. But your hand is still shaking. And your veins... look. They're black, Kael." } }
      }
    },
    "dialogue.aether.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Face à la peur de Lyra" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Facing Lyra's fear" } }
      }
    },
    "dialogue.aether.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "C'est temporaire. Ça passe toujours." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "It's temporary. It always fades." } }
      }
    },
    "dialogue.aether.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "« Toujours » ? Depuis combien de temps tu fais ça, Kael ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "\"Always\"? How long have you been doing this, Kael?" } }
      }
    },
    "dialogue.aether.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu aurais préféré que je la laisse te tuer ?" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Would you have preferred I let it kill you?" } }
      }
    },
    "dialogue.aether.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Non. Mais il y a une différence entre se battre et... ce que tu as fait à la fin." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No. But there's a difference between fighting and... what you did at the end." } }
      }
    },
    "dialogue.aether.choice3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je ne contrôle pas encore ce pouvoir. Mais il m'obéit. C'est suffisant." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I don't control this power yet. But it obeys me. That's enough." } }
      }
    },
    "dialogue.aether.response3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "« Il m'obéit. » Tu t'entends ? On dirait que tu parles d'un animal sauvage, pas d'une partie de toi." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "\"It obeys me.\" Do you hear yourself? You sound like you're talking about a wild animal, not a part of you." } }
      }
    },
    "dialogue.aether.lyra3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le sanctuaire est plus loin. Si quelque chose peut expliquer ta marque, c'est là-bas. Mais Kael..." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The sanctuary is further ahead. If anything can explain your mark, it's there. But Kael..." } }
      }
    },
    "dialogue.aether.kael2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je sais. Tu veux que je promette de ne pas m'en servir. Mais je ne fais pas de promesses que je ne peux pas tenir." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I know. You want me to promise not to use it. But I don't make promises I can't keep." } }
      }
    },

    "dialogue.shrine.voiceName" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Voix" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Voice" } }
      }
    },
    "dialogue.shrine.voice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu es revenu. Je savais que tu reviendrais. Le vide reconnaît les siens." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You came back. I knew you would. The void recognizes its own." } }
      }
    },
    "dialogue.shrine.voice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ils te retiendront. La fille avec son bâton. Le chef avec sa peur. Ils appellent ça de la prudence." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "They will hold you back. The girl with her staff. The chief with his fear. They call it caution." } }
      }
    },
    "dialogue.shrine.voice3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Moi, je peux te rendre ce qu'ils t'ont pris. Ta mémoire. Ton nom. Tout ce que tu étais avant le fossé." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I can give you back what they took. Your memory. Your name. Everything you were before the ditch." } }
      }
    },
    "dialogue.shrine.lyra1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Kael, ne l'écoute pas ! Cette voix... c'est la même énergie que ta marque. C'est un piège !" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Kael, don't listen! That voice... it's the same energy as your mark. It's a trap!" } }
      }
    },
    "dialogue.shrine.prompt" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le choix de Kael" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Kael's choice" } }
      }
    },
    "dialogue.shrine.choice1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tourner le dos au sanctuaire. Sans un mot." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Turn away from the sanctuary. Without a word." } }
      }
    },
    "dialogue.shrine.response1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu reviendras. Ils reviennent tous." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You'll come back. They all come back." } }
      }
    },
    "dialogue.shrine.choice2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ma mémoire est un prix que je suis prêt à payer." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "My memory is a price I'm willing to pay." } }
      }
    },
    "dialogue.shrine.response2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Admirable. Mais le vide ne demande pas de permission. Il prend." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Admirable. But the void doesn't ask permission. It takes." } }
      }
    },
    "dialogue.shrine.choice3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Dis-moi qui je suis. Je déciderai ensuite." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Tell me who I am. I'll decide after." } }
      }
    },
    "dialogue.shrine.response3" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu étais quelqu'un qui ne posait pas de questions. Quelqu'un qui prenait." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You were someone who didn't ask questions. Someone who took." } }
      }
    },
    "dialogue.shrine.lyra2" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Kael... tes yeux. Pendant un instant, ils étaient complètement noirs. Tu me fais peur." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Kael... your eyes. For a moment, they were completely black. You're scaring me." } }
      }
    },
    "dialogue.shrine.kael1" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "On rentre. Pour l'instant." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Let's go back. For now." } }
      }
    },

    "hud.objective.village" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Explore le village de Solis" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Explore the village of Solis" } }
      }
    },
    "hud.quest.delivery" : {
      "localizations" : {
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Quête: livrer le colis à Garen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Quest: deliver the package to Garen" } }
      }
    },

    "shop.bram.title" : {
