      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My moonherb stores are empty. It only grows in the forest, where the moon touches the ground."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mes réserves d'herbe lunaire sont vides. Elle ne pousse que dans la forêt, là où la lune touche le sol."
